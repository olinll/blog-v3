[{"data":1,"prerenderedAt":332},["ShallowReactive",2],{"content:\u002F2025\u002Fhalo-hao-navigation":3,"surround:\u002F2025\u002Fhalo-hao-navigation":321},{"id":4,"title":5,"body":6,"categories":295,"date":297,"description":298,"draft":299,"extension":300,"image":301,"meta":302,"navigation":304,"path":305,"permalink":301,"published":301,"readingTime":306,"recommend":301,"references":301,"seo":311,"sitemap":312,"stem":313,"tags":314,"top":299,"type":318,"updated":319,"__hash__":320},"content\u002Fposts\u002F2025\u002Fhalo-hao-navigation.md","Halo博客Hao主题添加个人导航页",{"type":7,"value":8,"toc":281},"minimark",[9,30,40,45,48,53,56,59,66,77,87,90,101,105,112,120,124,134,137,145,148,151,165,171,175,186,192,195,198,204,207,210,214,217,227,233,237,240,243,249,252,259,262,277],[10,11,12,24,27],"blockquote",{},[13,14,15,16,23],"p",{},"本教程是修改的主题是",[17,18,22],"a",{"href":19,"rel":20},"https:\u002F\u002Fgithub.com\u002Fchengzhongxue\u002Fhalo-theme-hao",[21],"nofollow","Halo-theme-Hao"," 版本是：1.6.6",[13,25,26],{},"根据友联页面修改而来。",[13,28,29],{},"原理是添加链接，给分组添加一个自定义属性，通过属性过滤展示的链接",[13,31,32],{},[33,34,35,36],"del",{},"效果如图：",[17,37,39],{"href":38},"#","前往：导航页",[41,42],"pic",{"caption":43,"src":44},"效果图","https:\u002F\u002Foss.olinl.com\u002Fhalo-hao-navigation\u002F20260627153511_r30d.webp",[13,46,47],{},"下面就开始教程吧！",[49,50,52],"h2",{"id":51},"修改halo运行配置","修改Halo运行配置",[13,54,55],{},"在运行时会缓存模板文件，下次访问不再会读取物理的模板文件，这会有性能的损耗。",[13,57,58],{},"如果我们修改主题，可以添加一个运行参数",[13,60,61],{},[17,62,65],{"href":63,"rel":64},"https:\u002F\u002Fdocs.halo.run\u002Fdeveloper-guide\u002Ftheme\u002Fprepare#%E6%90%AD%E5%BB%BA%E5%BC%80%E5%8F%91%E7%8E%AF%E5%A2%83",[21],"搭建开发环境",[67,68,70],"alert",{"type":69},"warning",[13,71,72,76],{},[73,74,75],"code",{"code":75},"--spring.thymeleaf.cache=false"," 仅用于开发调试，生产环境必须移除此参数，否则会严重影响性能。",[78,79,85],"pre",{"className":80,"code":82,"language":83,"meta":84},[81],"language-shell","# 关闭主题模板缓存\n- --spring.thymeleaf.cache=false\n","shell","",[73,86,82],{"__ignoreMap":84},[49,88,89],{"id":89},"创建navigation模板页面",[13,91,92,93,96,97,100],{},"首先先找到主题文件夹：在持久化存储的",[73,94,95],{"code":95},"halo2","文件夹下的",[73,98,99],{"code":99},"themes\u002Ftheme-hao","里面",[49,102,104],{"id":103},"修改themeyaml配置","修改theme.yaml配置",[13,106,107,108,111],{},"找到",[73,109,110],{"code":110},"spec.customTemplates.page","添加一个导航页面模板：",[78,113,118],{"className":114,"code":116,"language":117,"meta":84},[115],"language-yaml","spec:\n  displayName: Hao\n  author:\n    name: 程序员小航 & 困困鱼 & Carol\n    website: https:\u002F\u002Fgithub.com\u002Fchengzhongxue\n  customTemplates:\n    page:\n      - name: 友情链接页面模版\n        description: 支持可预设文本的友链\n        screenshot:\n        file: page_links.html\n      # 添加导航页面模板\n      - name: 导航页面模板\n        description: 个人导航页\n        screenshot:\n        file: navigation.html\n","yaml",[73,119,116],{"__ignoreMap":84},[49,121,123],{"id":122},"添加navigationhtml","添加navigation.html",[13,125,126,127,130,131],{},"在",[73,128,129],{"code":129},"templates","目录下新建一个文件",[73,132,133],{"code":133},"navigation.html",[13,135,136],{},"添加如下内容：",[78,138,143],{"className":139,"code":141,"language":142,"meta":84},[140],"language-html","\u003C!DOCTYPE html>\n\u003Chtml  xmlns:th=\"http:\u002F\u002Fwww.thymeleaf.org\"\n      th:replace=\"~{modules\u002Flayouts\u002Flayout :: layout(content = ~{::content}, htmlType = 'page',title = ${singlePage.spec.title + ' | ' + site.title}, head = ~{::head})}\">\n\u003Cth:block th:fragment=\"head\">\n    \u003Cth:block th:replace=\"~{modules\u002Fcommon\u002Fopen-graph :: open-graph(_title = ${singlePage.spec.title},\n                _permalink = ${singlePage.status.permalink},\n                _cover = ${singlePage.spec.cover},\n                _excerpt = ${singlePage.status.excerpt},\n                _type = 'website')}\">\u003C\u002Fth:block>\n\u003C\u002Fth:block>\n\u003Cth:block th:fragment=\"content\">\n\n    \u003Cdiv class=\"page\" id=\"body-wrap\">\n        \u003Cheader class=\"not-top-img\" id=\"page-header\">\n            \u003Cnav th:replace=\"~{modules\u002Fnav :: nav(title = ${singlePage.spec.title})}\">\u003C\u002Fnav>\n            \u003Clink rel=\"stylesheet\" type=\"text\u002Fcss\" th:href=\"${assets_link + '\u002Flibs\u002Ffcircle\u002Fheo-fcircle3.css'}\">\n\n        \u003C\u002Fheader>\n        \u003Cmain class=\"layout hide-aside\" id=\"content-inner\">\n            \u003Cdiv id=\"page\">\n                \u003Cth:block th:replace=\"~{macro\u002Fcontent-nav :: content-nav(${htmlType})}\" \u002F>\n                \u003Chr\u002F>\n                \u003C!--\u002F* 评论组件 *\u002F-->\n                \u003Cth:block\n                        th:replace=\"~{modules\u002Fcomment :: comment(group = 'content.halo.run',\n                  kind = 'SinglePage',\n                  name = ${singlePage.metadata.name},\n                  allowComment = ${singlePage.spec.allowComment})}\"\u002F>\n            \u003C\u002Fdiv>\n        \u003C\u002Fmain>\n        \u003C!-- 底部 -->\n        \u003Cfooter th:replace=\"~{modules\u002Ffooter}\"\u002F>\n    \u003C\u002Fdiv>\n\n\u003C\u002Fth:block>\n\n\u003C\u002Fhtml>\n","html",[73,144,141],{"__ignoreMap":84},[146,147],"hr",{},[13,149,150],{},"如果想要知道如何修改的，看下面：",[13,152,153,154,157,158,161,162],{},"将友联对应的html文件复制过来，修改",[73,155,156],{"code":156},"th:block th:replace","标签里面的",[73,159,160],{"code":160},"content-links"," 改为",[73,163,164],{"code":164},"content-nav",[78,166,169],{"className":167,"code":168,"language":142,"meta":84},[140],"\u003Cth:block th:replace=\"~{macro\u002Fcontent-links :: content-links(${htmlType})}\" \u002F>\n改为\n \u003Cth:block th:replace=\"~{macro\u002Fcontent-nav :: content-nav(${htmlType})}\" \u002F>\n",[73,170,168],{"__ignoreMap":84},[49,172,174],{"id":173},"创建conten-navhtml","创建conten-nav.html",[13,176,177,178,181,182,185],{},"在主题的",[73,179,180],{"code":180},"templates\u002Fmacro","文件夹的下创建",[73,183,184],{"code":184},"conten-nav.html","文件",[78,187,190],{"className":188,"code":189,"language":142,"meta":84},[140],"\u003Cth:block th:fragment=\"content-nav(htmlType)\">\n\n    \u003Cth:block th:with=\"groups = ${linkFinder.groupBy()}\">\n        \u003Cdiv th:replace=\"~{macro\u002Fauthor-content :: author-content(background = ${theme.config.moment.backgroundImg},\n                        smallTitle = '效率',\n                        bigTitle = '个人导航页',\n                        detail = '',\n                        buttonUrl = '',\n                        buttonTitle = '')}\">\u003C\u002Fdiv>\n\n        \u003C!--互动友链-->\n\n        \u003Cdiv class=\"flink\" id=\"article-container\">\n\n            \u003Cth:block th:each=\"group,iterStat : ${groups}\">\n                \u003C!-- 只显示 LinkOrFriend 注解等于 \"Link\" 的分组 -->\n                \u003Cth:block th:if=\"${!group.metadata.annotations.containsKey('LinkOrFriend')\n                  or #strings.isEmpty(group.metadata.annotations['LinkOrFriend'])\n                  or #strings.equals(group.metadata.annotations['LinkOrFriend'], 'Link')}\">\n                \u003Ch2 th:if=\"${not #lists.isEmpty(group.spec.displayName)}\">\n                    \u003Ca class=\"headerlink\" th:href=\"'#'+${group.spec.displayName}+'-'+${group.links.size}\"\n                       th:title=\"${group.spec.displayName}+ '('+${group.links.size}+')'\">\u003C\u002Fa>\n                    [[${group.spec.displayName}]] ([[${group.links.size}]])\n                \u003C\u002Fh2>\n\n                \u003Cdiv class=\"flink-desc\" th:if=\"${not #strings.isEmpty(#annotations.get(group, 'description'))}\">[[${#annotations.get(group, 'description')}]]\u003C\u002Fdiv>\n\n                \u003C!-- 第一个，使用卡片展示 -->\n                \u003Cdiv th:if=\"${#strings.equals(#annotations.get(group, 'displayStyle'),'beautify') && not #lists.isEmpty(group.links)}\"\n                     class=\"site-card-group\">\n\n                    \u003Cdiv class=\"site-card\" th:each=\"link : ${group.links}\">\n                        \u003Cspan th:if=\"${not #strings.isEmpty(#annotations.get(link, 'label'))}\"\n                              th:style=\"'background-color:' + ${#annotations.get(link,'labelColor')}\"\n                              class=\"site-card-tag\">[[${#annotations.get(link, 'label')}]]\u003C\u002Fspan>\n\n                        \u003Ca class=\"img\" target=\"_blank\" th:href=\"${link.spec.url}\" th:title=\"${link.spec.displayName}\">\n                            \u003Cimg class=\"flink-avatar\" style=\"pointer-events: none;\" th:alt=\"${link.spec.displayName}\"\n                                 th:with=\"img = @{${#strings.isEmpty(#annotations.get(link, 'siteshot')) ? link.spec.logo : #annotations.get(link,'siteshot') }}\"\n\n                                 th:src=\"${isLazyload ? loadingImg : img}\"\n                                 th:data-lazy-src=\"${ isLazyload ? img : ''}\">\n                        \u003C\u002Fa>\n\n                        \u003Ca class=\"info cf-friends-link\" target=\"_blank\" th:href=\"${link.spec.url}\"\n                           th:title=\"${link.spec.displayName}\">\n                            \u003Cdiv class=\"site-card-avatar no-lightbox\">\n                                \u003Cimg class=\"flink-avatar cf-friends-avatar\" th:alt=\"${link.spec.displayName}\"\n\n                                     th:src=\"${isLazyload ? loadingImg : link.spec.logo}\"\n                                     th:data-lazy-src=\"${ isLazyload ? link.spec.logo : ''}\">\n                            \u003C\u002Fdiv>\n                            \u003Cdiv class=\"site-card-text\">\n                                \u003Cspan class=\"title cf-friends-name\" th:text=\"${link.spec.displayName}\">\u003C\u002Fspan>\n                                \u003Cspan class=\"desc\" th:text=\"${link.spec.description}\"\n                                      th:title=\"${link.spec.description}\">\u003C\u002Fspan>\n                            \u003C\u002Fdiv>\n                        \u003C\u002Fa>\n                    \u003C\u002Fdiv>\n\n\n                \u003C\u002Fdiv>\n\n                \u003Cdiv class=\"flink-list\"\n                     th:if=\"${#strings.equals(#annotations.get(group, 'displayStyle'),'default') && not #lists.isEmpty(group.links)}\">\n                    \u003Cdiv class=\"flink-list-item\" th:each=\"link : ${group.links}\">\n                        \u003Cspan th:if=\"${not #strings.isEmpty(#annotations.get(link, 'label'))}\"\n                              th:style=\"'background-color:' + ${#annotations.get(link,'labelColor')}\"\n                              class=\"site-card-tag\">[[${#annotations.get(link, 'label')}]]\u003C\u002Fspan>\n                        \u003Ca class=\"cf-friends-link\" rel=\"external nofollow\" target=\"_blank\" th:href=\"${link.spec.url}\"\n                           th:title=\"${link.spec.displayName}\">\n                            \u003Cimg class=\"flink-avatar cf-friends-avatar\" th:alt=\"${link.spec.displayName}\"\n\n                                 th:src=\"${isLazyload ? loadingImg : link.spec.logo}\"\n                                 th:data-lazy-src=\"${ isLazyload ? link.spec.logo : ''}\">\n                            \u003Cdiv class=\"flink-item-info no-lightbox\">\n                                \u003Cspan class=\"flink-item-name cf-friends-name\" th:text=\"${link.spec.displayName}\">\u003C\u002Fspan>\n                                \u003Cspan class=\"flink-item-desc\" th:text=\"${link.spec.description}\"\n                                      th:title=\"${link.spec.description}\">\u003C\u002Fspan>\n                                \u003Cimg\n                                     th:src=\"${isLazyload ? loadingImg : link.spec.logo}\"\n                                     th:data-lazy-src=\"${ isLazyload ? link.spec.logo : ''}\">\n                            \u003C\u002Fdiv>\n                        \u003C\u002Fa>\n                    \u003C\u002Fdiv>\n                \u003C\u002Fdiv>\n\n                \u003Cdiv class=\"flink-list mini\"\n                     th:if=\"${#strings.equals(#annotations.get(group, 'displayStyle'),'deprecated') && not #lists.isEmpty(group.links)}\">\n                    \u003Cdiv class=\"flink-list-item\" th:each=\"link : ${group.links}\">\n                        \u003Ca class=\"cf-friends-link\" rel=\"external nofollow\" target=\"_blank\" th:href=\"${link.spec.url}\"\n                           th:title=\"${link.spec.displayName}\">\n                            \u003Cimg class=\"flink-avatar cf-friends-avatar\"\n\n                                 th:src=\"${isLazyload ? loadingImg : link.spec.logo}\"\n                                 th:data-lazy-src=\"${ isLazyload ? link.spec.logo : ''}\"\n                                 th:alt=\"${link.spec.displayName}\">\n                            \u003Cdiv class=\"img-alt is-center\">[[${link.spec.displayName}]]\u003C\u002Fdiv>\n                            \u003Cdiv class=\"flink-item-info\">\n                                \u003Cspan class=\"flink-item-name cf-friends-name\">[[${link.spec.displayName}]]\u003C\u002Fspan>\n                                \u003Cspan class=\"flink-item-desc\"\n                                      th:title=\"${link.spec.description}\">[[${link.spec.description}]]\u003C\u002Fspan>\n                            \u003C\u002Fdiv>\n                        \u003C\u002Fa>\n                    \u003C\u002Fdiv>\n                \u003C\u002Fdiv>\n                \u003C\u002Fth:block>\n            \u003C\u002Fth:block>\n\n            \u003Cth:block th:if=\"${not #strings.isEmpty(theme.config.link.linksArticle)}\"\n                      th:utext=\"${theme.config.link.linksArticle}\"> \u003C\u002Fth:block>\n\n            \u003Cscript>\n                var fdataUser = {\n                    jsonurl: '',\n                    apiurl: \"[(${theme.config.fcircle.apiurl})]\",\n                    apipublicurl: '', \u002F\u002F默认公共库\n                    initnumber: 20,  \u002F\u002F首次加载文章数\n                    stepnumber: 20,  \u002F\u002F更多加载文章数\n                    article_sort: 'created', \u002F\u002F文章排序 updated or created\n                    error_img: 'https:\u002F\u002Fsdn.geekzu.org\u002Favatar\u002F57d8260dfb55501c37dde588e7c3852c'\n                }\n            \u003C\u002Fscript>\n            \u003Cscript  th:src=\"@{\u002Fassets\u002Flibs\u002Ffcircle\u002Fheo-fcircle3mini.js}\">\u003C\u002Fscript>\n\n            \u003Cth:block th:if=\"${htmlType == 'page'}\" th:utext=\"${singlePage.content.content}\">\n            \u003C\u002Fth:block>\n\n        \u003C\u002Fdiv>\n\n    \u003C\u002Fth:block>\n\u003C\u002Fth:block>\n\n",[73,191,189],{"__ignoreMap":84},[13,193,194],{},"该组件是从友联页面拷贝而来，上面图片使用的是moments.html里面的。如需修改请自行修改",[13,196,197],{},"其中：",[78,199,202],{"className":200,"code":201,"language":142,"meta":84},[140],"\u003Cth:block th:if=\"${!group.metadata.annotations.containsKey('LinkOrFriend')\n                  or #strings.isEmpty(group.metadata.annotations['LinkOrFriend'])\n                  or #strings.equals(group.metadata.annotations['LinkOrFriend'], 'Link')}\">\n    \n  \u003C!-- 是只显示 LinkOrFriend 注解等于 \"Link\" 的分组 -->\n",[73,203,201],{"__ignoreMap":84},[49,205,206],{"id":206},"修改links",[13,208,209],{},"要让友联页面只显示友联的链接。",[49,211,213],{"id":212},"修改content-linkshtml","修改content-links.html",[13,215,216],{},"这个页面为展示的链接",[13,218,107,219,222,223,226],{},[73,220,221],{"code":221},"macro\\content-links.html","，大概28行有一个",[73,224,225],{"code":225},"\u003Cth:block th:each=\"group : ${groups}\">","修改为以下：",[78,228,231],{"className":229,"code":230,"language":142,"meta":84},[140],"\u003Cth:block th:each=\"group : ${groups}\"\n                              th:if=\"${group.metadata != null\n                                 and group.metadata.annotations != null\n                                 and #strings.equals(group.metadata.annotations['LinkOrFriend'], 'Friend')}\">\n",[73,232,230],{"__ignoreMap":84},[49,234,236],{"id":235},"修改links-canvashtml","修改links-canvas.html",[13,238,239],{},"这个页面为展示的互动canvas",[13,241,242],{},"到最底下修改JavaScript脚本：",[78,244,247],{"className":245,"code":246,"language":142,"meta":84},[140]," \u003Cscript th:inline=\"javascript\">\n        function refreshFrame() {\n            document.getElementById('iframe').contentWindow.location.reload(true);\n        }\n        const group = [[${ groups }]]\n\n        \u002F\u002F 只保留：LinkOrFrend 有值 且 等于 'Frend'\n        const filteredGroups = groups.filter(group => {\n            const value = group?.metadata?.annotations?.['LinkOrFriend'];\n            return value !== undefined && value !== null && value === 'Friend';\n        });\n\n        const logos = filteredGroups\n            .flatMap(group => group.links || [])\n            .map(link => link.spec?.logo)\n            .filter(logo => logo && typeof logo === 'string' && logo.trim() !== '');\n\n        localStorage.setItem('logos', JSON.stringify(logos))\n    \u003C\u002Fscript>\n",[73,248,246],{"__ignoreMap":84},[49,250,251],{"id":251},"创建页面",[13,253,254,255,258],{},"在后台创建一个页面，自定义模板选择我们刚才创建的",[73,256,257],{"code":257},"导航页面模板","，进行发布。",[49,260,261],{"id":261},"创建链接",[13,263,264,265,268,269,272,273,276],{},"随后在后台的",[73,266,267],{"code":267},"链接","里面添加分组自定义一个参数",[73,270,271],{"code":271},"LinkOrFriend=Friend","就在友联里面显示，",[73,274,275],{"code":275},"LinkOrFriend=Link","或者不填写，就在导航页里面显示",[41,278],{"caption":279,"src":280},"创建链接 配置自定义数据","https:\u002F\u002Foss.olinl.com\u002Fhalo-hao-navigation\u002F20260627153655_p9en.webp",{"title":84,"searchDepth":282,"depth":282,"links":283},4,[284,286,287,288,289,290,291,292,293,294],{"id":51,"depth":285,"text":52},2,{"id":89,"depth":285,"text":89},{"id":103,"depth":285,"text":104},{"id":122,"depth":285,"text":123},{"id":173,"depth":285,"text":174},{"id":206,"depth":285,"text":206},{"id":212,"depth":285,"text":213},{"id":235,"depth":285,"text":236},{"id":251,"depth":285,"text":251},{"id":261,"depth":285,"text":261},[296],"服务","2025-11-09","详解如何在Halo博客中添加个人导航页，包括添加链接、分组、自定义属性等。",false,"md",null,{"slots":303},{},true,"\u002F2025\u002Fhalo-hao-navigation",{"text":307,"minutes":308,"time":309,"words":310},"6 min read",5.7,342000,1140,{"title":5,"description":298},{"loc":305},"posts\u002F2025\u002Fhalo-hao-navigation",[315,316,317],"Halo","主题","导航页","tech","2026-06-27 15:16:40","mXimvOCnG6xlNAW1kmVhxl-senVHGmsvKtbF9TtfjWM",[322,327],{"title":323,"path":324,"stem":325,"date":326,"type":318,"children":-1},"Docker 部署 Sun-Panel 导航面板","\u002F2025\u002Fdocker-sun-panel","posts\u002F2025\u002Fdocker-sun-panel","2025-10-09 15:13:16",{"title":328,"path":329,"stem":330,"date":331,"type":318,"children":-1},"利用EdgeOne Pages给飞牛容器一个固定域名","\u002F2025\u002Fedgeone-fndocker","posts\u002F2025\u002Fedgeone-fndocker","2025-11-28 15:16:40",1782547829070]
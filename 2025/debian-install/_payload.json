[{"data":1,"prerenderedAt":902},["ShallowReactive",2],{"content:\u002F2025\u002Fdebian-install":3,"surround:\u002F2025\u002Fdebian-install":891},{"id":4,"title":5,"body":6,"categories":866,"date":868,"description":869,"draft":870,"extension":871,"image":872,"meta":873,"navigation":875,"path":876,"permalink":872,"published":872,"readingTime":877,"recommend":872,"references":872,"seo":882,"sitemap":883,"stem":884,"tags":885,"top":870,"type":888,"updated":889,"__hash__":890},"content\u002Fposts\u002F2025\u002Fdebian-install.md","Debian 13 稳定版安装指南及系统配置",{"type":7,"value":8,"toc":838},"minimark",[9,14,26,37,45,49,54,62,67,71,78,82,86,89,93,97,100,104,108,111,125,134,138,144,147,153,164,168,174,177,183,187,197,201,207,211,215,222,226,285,289,292,297,301,306,310,318,322,326,329,375,378,381,385,388,392,406,410,424,427,430,433,436,439,442,445,448,452,455,459,462,465,468,471,478,481,484,487,490,493,508,511,515,518,526,529,549,552,555,558,562,565,568,575,578,581,585,589,595,600,607,638,643,649,653,656,663,666,672,676,689,692,698,702,705,711,715,721,725,731,736,742,828,832],[10,11,13],"h2",{"id":12},"一下载镜像","一、下载镜像",[15,16,17,18,25],"p",{},"国内用户推荐在「清华大学开源软件镜像站」的 ",[19,20,24],"a",{"href":21,"rel":22},"https:\u002F\u002Fmirrors.tuna.tsinghua.edu.cn\u002Fdebian-cd\u002Fcurrent\u002F",[23],"nofollow","debian-cd 专属页面","，找到与你「设备架构」相匹配的 Debian 13 ISO 镜像，然后自行下载。",[27,28,29],"alert",{},[15,30,31,32,36],{},"建议根据你的设备架构，选择",[33,34,35],"code",{"code":35},"iso-dvd","完整安装镜像。",[15,38,39,40],{},"amd 架构链接：",[19,41,44],{"href":42,"rel":43},"https:\u002F\u002Fmirrors.tuna.tsinghua.edu.cn\u002Fdebian-cd\u002Fcurrent\u002Famd64\u002Fiso-dvd\u002F",[23],"AMD - ISO DVD",[10,46,48],{"id":47},"二开始安装","二、开始安装",[50,51,53],"h3",{"id":52},"_1-选择安装类型","1. 选择安装类型",[15,55,56,57,61],{},"在 Debian 安装程序菜单中，选择 「",[58,59,60],"strong",{},"Graphical Install","」，以图形化界面启动 Debian 13 安装向导。",[63,64],"pic",{"src":65,"caption":66},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627101657_r7u6.webp","选择安装类型",[50,68,70],{"id":69},"_2-选择语言","2. 选择语言",[15,72,73,74,77],{},"选择「安装向导」和系统中要使用的语言，然后点击「Continue」继续。国内的小伙伴选择「",[58,75,76],{},"中文（简体）","」即可。",[63,79],{"src":80,"caption":81},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627101715_se2t.webp","选择语言",[50,83,85],{"id":84},"_3-选择你的位置","3. 选择你的位置",[15,87,88],{},"选择你所在的地理位置，系统会以此自动为 Debian 13 设置时区。",[63,90],{"src":91,"caption":92},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627101730_00vm.webp","选择位置",[50,94,96],{"id":95},"_4-配置键盘","4. 配置键盘",[15,98,99],{},"在列表中选择与你「实体键盘」相匹配的键盘布局，然后点击「继续」。",[63,101],{"src":102,"caption":103},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627101749_bgr5.webp","配置键盘",[50,105,107],{"id":106},"_5-网络配置","5. 网络配置",[15,109,110],{},"在安装过程中，Debian 安装程序会尝试通过 DHCP 服务器，自动获取 IP 地址来配置网络：",[112,113,114,122],"ul",{},[115,116,117,118,121],"li",{},"如果获取成功，就会直接跳到「主机名」设置（这在安装「桌面版」时比较适用）。如果是安装 Debian 服务器，",[58,119,120],{},"可以在「主机名」设置界面点击「返回」，手动指定固定 IP","。",[115,123,124],{},"如果网络中没有可用的 DHCP 服务器，自动配置将会失败，也需要你手动指定 IP 地址。",[27,126,128,131],{"type":127},"warning",[15,129,130],{},"如果你的网络中有 DHCP 服务器，系统自动配置了，可以点击返回按钮，选择返回，然后按照下面教程继续即可",[63,132],{"src":133},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627101832_ucc3.webp",[135,136,137],"h4",{"id":137},"手动配置网络",[139,140,141],"ol",{},[115,142,143],{},"选择「手动配置网络」，然后点击「继续」。",[63,145],{"src":146,"caption":137},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627101905_ja68.webp",[139,148,150],{"start":149},2,[115,151,152],{},"输入一个固定 IP 地址，然后点击「继续」。",[27,154,155,161],{},[15,156,157,158],{},"可以在这里输入 IP 地址\u002F子网掩码，例如 ",[33,159,160],{"code":160},"192.168.1.2\u002F24",[15,162,163],{},"或者只输入 IP 地址，在后面配置子网掩码",[63,165],{"src":166,"caption":167},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627101936_kpb5.webp","配置静态IP地址",[139,169,171],{"start":170},3,[115,172,173],{},"输入网关 IP 地址，然后点击「继续」。通常会自动配置。",[63,175],{"src":176},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102013_m70d.webp",[139,178,180],{"start":179},4,[115,181,182],{},"输入 DNS 服务器，然后点击「继续」。如何要配置多个 DNS 服务器，可以用「空格」隔开。",[63,184],{"src":185,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102025_8yw2.webp","null",[139,188,190],{"start":189},5,[115,191,192,193,196],{},"为你的 Debian 13 系统设置一个 ",[33,194,195],{"code":195},"hostname"," 主机名，然后点击「继续」。",[63,198],{"src":199,"caption":200},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102045_9qh4.webp","配置主机名",[139,202,204],{"start":203},6,[115,205,206],{},"如果你有与网络关联的特定「域名」，可以在这里输入。一般情况下，我们会选择「留空」。",[63,208],{"src":209,"caption":210},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102112_d1ve.webp","配置局域网Domain",[50,212,214],{"id":213},"_6-设置-root-密码","6. 设置 Root 密码",[15,216,217,218,221],{},"为",[33,219,220],{"code":220},"root","帐户设置一个强密码。",[63,223],{"src":224,"caption":225},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102138_lij7.webp","配置密码",[27,227,230],{"type":228,"title":229},"question","强密码的标准",[231,232,233,246],"table",{},[234,235,236],"thead",{},[237,238,239,243],"tr",{},[240,241,242],"th",{},"要求",[240,244,245],{},"说明",[247,248,249,258,277],"tbody",{},[237,250,251,255],{},[252,253,254],"td",{},"长度",[252,256,257],{},"至少 8 位字符",[237,259,260,263],{},[252,261,262],{},"复杂性",[252,264,265,266,269,270,269,273,276],{},"包含大小写字母、数字和特殊字符（如",[33,267,268],{"code":268},"@","、",[33,271,272],{"code":272},"#",[33,274,275],{"code":275},"$","等）。",[237,278,279,282],{},[252,280,281],{},"安全性",[252,283,284],{},"避免重复使用或容易被猜到的密码",[50,286,288],{"id":287},"_7-创建新用户和密码","7. 创建新用户和密码",[15,290,291],{},"强烈建议你创建一个普通用户账户，作为日常操作使用。只在需要权限时再临时提权。",[139,293,294],{},[115,295,296],{},"输入新用户的全名，然后点击「继续」。可以和下一步的「用户名」不同。",[63,298],{"src":299,"caption":300},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102158_q3k8.webp","设置新用户名称",[139,302,303],{"start":149},[115,304,305],{},"为这个用户设置一个用户名，只能用小写字母和数字，而且必须以字母开头。",[63,307],{"src":308,"caption":309},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102220_o1m0.webp","设置新用户登录名",[139,311,312],{"start":170},[115,313,314,315,317],{},"为新用户设置一个强密码，最好是和 ",[33,316,220],{"code":220}," 密码不同。",[63,319],{"src":320,"caption":321},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102236_u13s.webp","设置新用户密码",[50,323,325],{"id":324},"_8-对磁盘进行分区","8. 对磁盘进行分区",[15,327,328],{},"在这一步，我们要规划磁盘分区，主要有以下 4 个选项：",[231,330,331,341],{},[234,332,333],{},[237,334,335,338],{},[240,336,337],{},"分区选项",[240,339,340],{},"描述",[247,342,343,351,359,367],{},[237,344,345,348],{},[252,346,347],{},"向导 – 使用整个磁盘",[252,349,350],{},"自动对整个磁盘进行分区，适合新手和 Homelab 虚拟机使用。",[237,352,353,356],{},[252,354,355],{},"向导 – 使用整个磁盘并配置 LVM",[252,357,358],{},"自动设置 LVM 分区。",[237,360,361,364],{},[252,362,363],{},"向导 – 使用整个磁盘并配置加密的 LVM",[252,365,366],{},"自动设置加密的 LVM 分区。",[237,368,369,372],{},[252,370,371],{},"手动",[252,373,374],{},"自定义分区，自由度最高，适合有经验的用户。",[15,376,377],{},"通常我们选择 1 或者 2 即可",[15,379,380],{},"我这里推荐使用 LVM 进行分区",[63,382],{"src":383,"caption":384},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102301_3ekx.webp","使用LVM分区",[15,386,387],{},"选择你要分区的硬盘",[63,389],{"src":390,"caption":391},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102408_pmlg.webp","选择磁盘",[15,393,394,395,269,398,401,402,405],{},"如果没有特殊需求，推荐选择「将所有文件放在同一个分区中」，你也可以将",[33,396,397],{"code":397},"\u002Fhome",[33,399,400],{"code":400},"\u002Fvar","和",[33,403,404],{"code":404},"\u002Ftmp","等目录单独分区。",[63,407],{"src":408,"caption":409},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102423_4vmj.webp","选择分区方式",[27,411,412,417,420],{"type":127},[15,413,414],{},[58,415,416],{},"这里确认你所选的硬盘，操作不可逆！！",[15,418,419],{},"这里如果硬盘不是空的，会提示下面内容，我们直接选择是即可。",[63,421],{"src":422,"caption":423},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102444_qbuk.webp","永久删除硬盘内容",[15,425,426],{},"选择「是」确认将修改写入磁盘并配置 LVM",[63,428],{"src":429,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102650_suyv.webp",[15,431,432],{},"这里默认保持最大空间即可",[63,434],{"src":435,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102701_0o7d.webp",[15,437,438],{},"完成分区操作并将修改写入磁盘",[63,440],{"src":441,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102711_tvop.webp",[15,443,444],{},"选择「是」确认将改动写入磁盘，然后点击「继续」。",[63,446],{"src":447,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102717_ufv9.webp",[50,449,451],{"id":450},"_9-开始安装基本系统","9. 开始安装基本系统",[63,453],{"src":454,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102726_nkon.webp",[50,456,458],{"id":457},"配置软件包管理器更新源","配置软件包管理器：更新源",[15,460,461],{},"安装向导会询问你是否扫描额外的安装介质，选择「否」继续。",[63,463],{"src":464,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102734_3qtd.webp",[15,466,467],{},"选择「是」，启用网络镜像。（配置一个快速的国内源，对国内的小伙伴非常重要。）",[63,469],{"src":470,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102743_rgwn.webp",[15,472,473,474,477],{},"国家选择「中国」，Debian 仓库镜像站点推荐选择 ",[33,475,476],{"code":476},"tsinghua"," 清华源。",[63,479],{"src":480,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102751_sahh.webp",[63,482],{"src":483,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102803_7ny3.webp",[15,485,486],{},"如果你是直连网络，HTTP 代理信息就「留空」；如果有代理，就填写代理地址和端口号。",[63,488],{"src":489,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102816_lww7.webp",[15,491,492],{},"启用「软件包流行度调查」后，Debian 会定期收集你的软件使用数据。如果你不想参与，就选择「否」。",[27,494,495,498],{},[15,496,497],{},"你也可以随时在「终端」中，执行以下命令来调整设置：",[499,500,506],"pre",{"className":501,"code":503,"language":504,"meta":505},[502],"language-bash","dpkg-reconfigure popularity-contest\n","bash","",[33,507,503],{"__ignoreMap":505},[63,509],{"src":510,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102826_oebn.webp",[50,512,514],{"id":513},"_10-软件选择桌面版还是服务器","10. 软件选择：桌面版还是服务器",[15,516,517],{},"Debian 是一款通用型 Linux 发行版，它不像 Ubuntu 那样，还单独区分桌面和服务器版本的 ISO 镜像。但你可以在「软件选择」时，来决定安装哪种类型：",[112,519,520,523],{},[115,521,522],{},"勾选「Debian 桌面环境」，并至少选择一款桌面，就会安装桌面版。",[115,524,525],{},"如果不选「Debian 桌面环境」，那就是服务器版。",[15,527,528],{},"选择要安装的软件，推荐勾选上：",[112,530,531,537,543],{},[115,532,533,536],{},[58,534,535],{},"SSH server","：安装 SSH 服务器，方便远程管理。Homelab 环境可以启用 root 登录。",[115,538,539,542],{},[58,540,541],{},"标准系统工具","：包括一些常用的基础工具包、命令行工具、网络工具和系统管理工具等。",[115,544,545,548],{},[58,546,547],{},"Blends","：适用于教育、科研等特定场景的软件合集。",[63,550],{"src":551,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102834_xk89.webp",[15,553,554],{},"选择完毕后，点击「继续」，开始安装这些软件。",[63,556],{"src":557,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102842_o4tp.webp",[50,559,561],{"id":560},"_11-安装-grub-启动引导器","11. 安装 GRUB 启动引导器",[15,563,564],{},"选择「是」继续安装 GRUB 启动引导器。",[63,566],{"src":567,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102850_zji4.webp",[15,569,570,571,574],{},"选择要安装 GRUB 的磁盘，比如",[33,572,573],{"code":573},"\u002Fdev\u002Fsda","，然后点击「继续」。",[63,576],{"src":577,":caption":186},"https:\u002F\u002Foss.olinl.com\u002Fdebian-install\u002F20260627102857_rm0r.webp",[15,579,580],{},"最后,点击「继续」重启系统，完成 Debian 13 安装流程。",[10,582,584],{"id":583},"三配置系统","三、配置系统",[50,586,588],{"id":587},"_1-root-账户允许远程登录","1. Root 账户允许远程登录",[499,590,593],{"className":591,"code":592,"language":504,"meta":505},[502],"# 查看是否安装了SSH服务\nps -ef |grep ssh \n\n# 没有安装的话，执行下面语句\nsudo apt-get update                   #先更新下资源列表\nsudo apt-get install openssh-server   #安装openssh-server\nsudo ps -ef | grep ssh                #查看是否安装成功\nsudo systemctl restart sshd           #重新启动SSH服务 \n\n# 进入ssh配置文件\nvi  \u002Fetc\u002Fssh\u002Fsshd_config\n",[33,594,592],{"__ignoreMap":505},[15,596,597],{},[58,598,599],{},"修改Root远程登录权限",[499,601,605],{"className":602,"code":603,"language":504,"meta":604},[502],"#PermitRootLogin prohibit-password\nPermitRootLogin yes # [!code ++]\n","title=\"\u002Fetc\u002Fssh\u002Fsshd_config\"",[33,606,603],{"__ignoreMap":505},[27,608,610,615,618],{"type":228,"title":609},"PermitRootLogin",[15,611,612,614],{},[33,613,609],{"code":609}," 是一个用于配置 SSH 服务器的选项。这个选项决定了是否允许 root 用户通过 SSH 直接登录到服务器。通常情况下，为了提高安全性，最好禁止 root 用户通过 SSH 直接登录，而是使用一个普通用户登录后再通过 su 或者 sudo 切换到 root 用户来执行需要特权的操作。这样可以降低系统受到攻击的风险。",[15,616,617],{},"常见的 PermitRootLogin 选项取值包括：",[112,619,620,626,632],{},[115,621,622,625],{},[33,623,624],{"code":624},"yes","：允许 root 用户通过 SSH 直接登录。",[115,627,628,631],{},[33,629,630],{"code":630},"no","：禁止 root 用户通过 SSH 直接登录。",[115,633,634,637],{},[33,635,636],{"code":636},"without-password","：允许 root 用户通过 SSH 密钥登录，但不允许使用密码登录。",[15,639,640],{},[58,641,642],{},"重启服务",[499,644,647],{"className":645,"code":646,"language":504,"meta":505},[502],"# 重启ssh服务\nsudo systemctl daemon-reload\nsudo systemctl restart ssh\n",[33,648,646],{"__ignoreMap":505},[50,650,652],{"id":651},"_2-换国内源","2. 换国内源",[15,654,655],{},"因为我们已经在安装的时候选择清华大学源了，所以这里只需要将 CD-ROM 部分注释或者删除就可以了",[499,657,661],{"className":658,"code":659,"filename":660,"language":504,"meta":505},[502],"# 删除或者注释掉这一行\n#deb cdrom:[Debian GNU\u002FLinux 13.3.0 _Trixie_ - Official amd64 DVD Binary-1 with firmware 20260110-11:00]\u002F trixie contrib main non-free-firmware\n\ndeb http:\u002F\u002Fmirrors.tuna.tsinghua.edu.cn\u002Fdebian\u002F trixie main non-free-firmware\ndeb-src http:\u002F\u002Fmirrors.tuna.tsinghua.edu.cn\u002Fdebian\u002F trixie main non-free-firmware\n\ndeb http:\u002F\u002Fsecurity.debian.org\u002Fdebian-security trixie-security main non-free-firmware\ndeb-src http:\u002F\u002Fsecurity.debian.org\u002Fdebian-security trixie-security main non-free-firmware\n\n# trixie-updates, to get updates before a point release is made;\n# see https:\u002F\u002Fwww.debian.org\u002Fdoc\u002Fmanuals\u002Fdebian-reference\u002Fch02.en.html#_updates_and_backports\ndeb http:\u002F\u002Fmirrors.tuna.tsinghua.edu.cn\u002Fdebian\u002F trixie-updates main non-free-firmware\ndeb-src http:\u002F\u002Fmirrors.tuna.tsinghua.edu.cn\u002Fdebian\u002F trixie-updates main non-free-firmware\n\n","\u002Fetc\u002Fapt\u002Fsources.list",[33,662,659],{"__ignoreMap":505},[15,664,665],{},"更新系统及其软件包",[499,667,670],{"className":668,"code":669,"language":504,"meta":505},[502],"apt update\napt upgrade\n",[33,671,669],{"__ignoreMap":505},[50,673,675],{"id":674},"_3-修复sudo权限","3. 修复sudo权限",[15,677,678,679,681,682,685,686,688],{},"Debian 和 Ubuntu 不同，如果在安装时设置了 ",[33,680,220],{"code":220}," 密码，系统默认不会把普通用户加入 ",[33,683,684],{"code":684},"sudo"," 组，甚至连 ",[33,687,684],{"code":684}," 命令都没装。",[15,690,691],{},"以下是修复步骤：",[499,693,696],{"className":694,"code":695,"language":504,"meta":505},[502],"# 切换到 root 用户\nsu -\n\n# 安装 sudo 软件包\napt update && apt install sudo -y\n\n# 将普通用户加入 sudo 组\n# 语法：usermod -aG sudo \u003C你的用户名>\nusermod -aG sudo olinl\n\n# 使权限生效\n## exit 退出或者索性 reboot重启\n\n",[33,697,695],{"__ignoreMap":505},[50,699,701],{"id":700},"_4-开启-bbr-网络加速","4. 开启 BBR 网络加速",[15,703,704],{},"既然是“最佳实践”配置，Debian 13 自带的高版本内核开启 BBR 只需要一行命令，能显著提升网络吞吐量，建议顺手做了：",[499,706,709],{"className":707,"code":708,"language":504,"meta":505},[502],"# 开启 BBR\necho \"net.core.default_qdisc=fq\" >> \u002Fetc\u002Fsysctl.conf\necho \"net.ipv4.tcp_congestion_control=bbr\" >> \u002Fetc\u002Fsysctl.conf\n\n# 应用配置\nsysctl -p\n\n",[33,710,708],{"__ignoreMap":505},[50,712,714],{"id":713},"_5-让debian命令行显示中文","5. 让Debian命令行显示中文",[499,716,719],{"className":717,"code":718,"language":504,"meta":505},[502],"# 方法A：直接编辑 \u002Fetc\u002Fprofile（在文件末尾添加）\nsudo tee -a \u002Fetc\u002Fprofile \u003C\u003C 'EOF'\n# 系统级语言设置\nexport LANG=zh_CN.UTF-8\nexport LC_ALL=zh_CN.UTF-8\nexport PATH=$PATH:\u002Fusr\u002Flocal\u002Fbin\nEOF\n",[33,720,718],{"__ignoreMap":505},[10,722,724],{"id":723},"四安装必要软件","四、安装必要软件",[499,726,729],{"className":727,"code":728,"language":504,"meta":505},[502],"apt install wget curl vim zip unzip lsb-release tree htop net-tools lsof chrony tar lvm2 parted sudo -y\n",[33,730,728],{"__ignoreMap":505},[15,732,733],{},[58,734,735],{},"安装 Intel 显卡工具包",[499,737,740],{"className":738,"code":739,"language":504,"meta":505},[502],"apt install vainfo intel-gpu-tools -y\n",[33,741,739],{"__ignoreMap":505},[112,743,744,750,756,762,768,774,780,786,792,798,804,810,816,822],{},[115,745,746,749],{},[58,747,748],{},"wget","：用于从命令行下载文件，适合脚本和大文件拉取",[115,751,752,755],{},[58,753,754],{},"curl","：用于发起 HTTP\u002FAPI 请求，常用于接口测试和自动化",[115,757,758,761],{},[58,759,760],{},"vim","：终端下的文本编辑器，用于修改配置和编写脚本",[115,763,764,767],{},[58,765,766],{},"zip","：将文件打包成 zip 格式，方便跨平台传输",[115,769,770,773],{},[58,771,772],{},"unzip","：解压 zip 压缩包",[115,775,776,779],{},[58,777,778],{},"lsb-release","：用于识别当前 Linux 发行版和版本信息",[115,781,782,785],{},[58,783,784],{},"tree","：以树状结构显示目录内容",[115,787,788,791],{},[58,789,790],{},"htop","：交互式进程监控工具，用于查看 CPU 和内存使用情况",[115,793,794,797],{},[58,795,796],{},"net-tools","：提供 netstat、ifconfig 等传统网络排错工具",[115,799,800,803],{},[58,801,802],{},"lsof","：查看端口或文件被哪个进程占用",[115,805,806,809],{},[58,807,808],{},"chrony","：高精度时间同步服务，保证系统时间准确",[115,811,812,815],{},[58,813,814],{},"tar","：Linux 常用的打包和解包工具",[115,817,818,821],{},[58,819,820],{},"lvm2",": 磁盘管理工具",[115,823,824,827],{},[58,825,826],{},"parted",":磁盘管理工具",[10,829,831],{"id":830},"五作为虚拟机安装-sr-iov-guest-核显驱动","五、作为虚拟机安装 SR-IOV-guest 核显驱动",[499,833,836],{"className":834,"code":835,"language":504,"meta":505},[502],"\nnano \u002Fetc\u002Fdefault\u002Fgrub\n\n# 在GRUB_CMDLINE_LINUX_DEFAULT后面加上 i915.enable_guc=3\n#GRUB_CMDLINE_LINUX_DEFAULT=\"quiet\"\nGRUB_CMDLINE_LINUX_DEFAULT=\"quiet i915.enable_guc=3\"\n\n# 更新grub\nupdate-grub\n\n# 安装相关环境和依赖包\napt install -y dkms vainfo intel-media-va-driver wget firmware-linux linux-headers-$(uname -r)\n\n# 下载sriov驱动\n# https:\u002F\u002Fgithub.com\u002Fstrongtz\u002Fi915-sriov-dkms\nwget https:\u002F\u002Fgithub.com\u002Fstrongtz\u002Fi915-sriov-dkms\u002Freleases\u002Fdownload\u002F2025.12.10\u002Fi915-sriov-dkms_2025.12.10_amd64.deb\n\n# 安装sriov驱动\nsudo dpkg -i i915-sriov-dkms_*_amd64.deb\n\n# 重启\nreboot\n\n",[33,837,835],{"__ignoreMap":505},{"title":505,"searchDepth":179,"depth":179,"links":839},[840,841,857,864,865],{"id":12,"depth":149,"text":13},{"id":47,"depth":149,"text":48,"children":842},[843,844,845,846,847,850,851,852,853,854,855,856],{"id":52,"depth":170,"text":53},{"id":69,"depth":170,"text":70},{"id":84,"depth":170,"text":85},{"id":95,"depth":170,"text":96},{"id":106,"depth":170,"text":107,"children":848},[849],{"id":137,"depth":179,"text":137},{"id":213,"depth":170,"text":214},{"id":287,"depth":170,"text":288},{"id":324,"depth":170,"text":325},{"id":450,"depth":170,"text":451},{"id":457,"depth":170,"text":458},{"id":513,"depth":170,"text":514},{"id":560,"depth":170,"text":561},{"id":583,"depth":149,"text":584,"children":858},[859,860,861,862,863],{"id":587,"depth":170,"text":588},{"id":651,"depth":170,"text":652},{"id":674,"depth":170,"text":675},{"id":700,"depth":170,"text":701},{"id":713,"depth":170,"text":714},{"id":723,"depth":149,"text":724},{"id":830,"depth":149,"text":831},[867],"系统","2025-10-08 10:14:30","深入讲解 Debian 13 最小化安装与常用服务配置。涵盖 APT 优化与权限管理，助你掌握这款“通用操作系统”的极致稳定方案。",false,"md",null,{"slots":874},{},true,"\u002F2025\u002Fdebian-install",{"text":878,"minutes":879,"time":880,"words":881},"13 min read",12.445,746700,2489,{"title":5,"description":869},{"loc":876},"posts\u002F2025\u002Fdebian-install",[886,887],"系统安装","Debian","tech","2026-06-27 10:14:30","ryJj4gYDu6vqoily9NCvXW8XxfoP_7rm7fpYXFT91k8",[892,897],{"title":893,"path":894,"stem":895,"date":896,"type":888,"children":-1},"Docker 配置私服自签名证书信任","\u002F2025\u002Fdocker-private-cert","posts\u002F2025\u002Fdocker-private-cert","2025-09-21 14:27:16",{"title":898,"path":899,"stem":900,"date":901,"type":888,"children":-1},"Immich 图片管理软件部署备忘录","\u002F2025\u002Fimmich-deploy","posts\u002F2025\u002Fimmich-deploy","2025-10-09",1782547830147]
[{"data":1,"prerenderedAt":161},["ShallowReactive",2],{"content:\u002F2025\u002Fdocker-private-cert":3,"surround:\u002F2025\u002Fdocker-private-cert":150},{"id":4,"title":5,"body":6,"categories":124,"date":126,"description":127,"draft":128,"extension":129,"image":130,"meta":131,"navigation":133,"path":134,"permalink":130,"published":130,"readingTime":135,"recommend":130,"references":130,"seo":140,"sitemap":141,"stem":142,"tags":143,"top":128,"type":147,"updated":148,"__hash__":149},"content\u002Fposts\u002F2025\u002Fdocker-private-cert.md","Docker 配置私服自签名证书信任",{"type":7,"value":8,"toc":118},"minimark",[9,22,33,38,48,54,60,64,67,73,80],[10,11,12,13,17,18,21],"p",{},"在内网部署私有镜像仓库（如 Harbor）时，通常使用自签名证书。客户端需要手动信任该证书，否则 ",[14,15,16],"code",{"code":16},"docker push"," \u002F ",[14,19,20],{"code":20},"docker pull"," 会报证书验证失败。",[23,24,25],"blockquote",{},[10,26,27,28],{},"如果你使用 Harbor 作为私服，参见 ",[29,30,32],"a",{"href":31},"\u002F2024\u002Fharbor-install\u002F","Harbor 私有镜像仓库安装指南",[34,35,37],"h2",{"id":36},"linux","Linux",[39,40,46],"pre",{"className":41,"code":43,"language":44,"meta":45},[42],"language-bash","# 1. 获取 Harbor 服务器的证书\nopenssl s_client -connect harbor.local:443 -showcerts \u003C\u002Fdev\u002Fnull 2>\u002Fdev\u002Fnull \\\n  | openssl x509 -outform PEM > harbor-cert.pem\n\n# 2. 创建 Docker 证书目录\nsudo mkdir -p \u002Fetc\u002Fdocker\u002Fcerts.d\u002Fharbor.local\n\n# 3. 复制证书到 Docker 信任目录\nsudo cp harbor-cert.pem \u002Fetc\u002Fdocker\u002Fcerts.d\u002Fharbor.local\u002Fca.crt\n\n# 4. 同时添加到系统 CA 证书（推荐）\nsudo cp harbor-cert.pem \u002Fusr\u002Flocal\u002Fshare\u002Fca-certificates\u002Fharbor.local.crt\nsudo update-ca-certificates\n","bash","",[14,47,43],{"__ignoreMap":45},[49,50,51],"note",{},[10,52,53],{},"重启 Docker 会短暂停止所有正在运行的容器，请在维护窗口内操作。",[39,55,58],{"className":56,"code":57,"language":44,"meta":45},[42],"# 5. 重启 Docker 服务\nsudo systemctl restart docker\n",[14,59,57],{"__ignoreMap":45},[34,61,63],{"id":62},"windows","Windows",[10,65,66],{},"在 Git Bash 中执行以下命令获取证书：",[39,68,71],{"className":69,"code":70,"language":44,"meta":45},[42],"echo | openssl s_client -connect harbor.local:443 -servername harbor.local 2>\u002Fdev\u002Fnull \\\n  | openssl x509 > harbor.local-ca.crt\n",[14,72,70],{"__ignoreMap":45},[10,74,75,76,79],{},"然后将 ",[14,77,78],{"code":78},"harbor-ca.crt"," 安装到系统受信任的根证书：",[81,82,83,89,96,103,109,115],"ol",{},[84,85,86,87],"li",{},"双击 ",[14,88,78],{"code":78},[84,90,91,92],{},"点击 ",[93,94,95],"strong",{},"安装证书...",[84,97,98,99,102],{},"选择 ",[93,100,101],{},"本地计算机"," → 下一步",[84,104,98,105,108],{},[93,106,107],{},"将所有证书放入下列存储"," → 浏览",[84,110,98,111,114],{},[93,112,113],{},"受信任的根证书颁发机构"," → 确定 → 下一步 → 完成",[84,116,117],{},"重启 Docker Desktop",{"title":45,"searchDepth":119,"depth":119,"links":120},4,[121,123],{"id":36,"depth":122,"text":37},2,{"id":62,"depth":122,"text":63},[125],"容器","2025-09-21 14:27:16","介绍如何在 Linux 和 Windows 客户端上配置 Docker 信任私有镜像仓库的自签名 SSL 证书，解决拉取推送时的证书验证失败问题。",false,"md",null,{"slots":132},{},true,"\u002F2025\u002Fdocker-private-cert",{"text":136,"minutes":137,"time":138,"words":139},"2 min read",1.425,85500,285,{"title":5,"description":127},{"loc":134},"posts\u002F2025\u002Fdocker-private-cert",[144,145,146],"Docker","Harbor","SSL","tech","2026-06-27 14:27:16","xh2ho1yrp3iSQS6oOLV7Pj-FvYhIe0NT3QYSXH9QR-E",[151,156],{"title":152,"path":153,"stem":154,"date":155,"type":147,"children":-1},"Chrome硬件加速功能开启与关闭","\u002F2025\u002Fchrome-hardware","posts\u002F2025\u002Fchrome-hardware","2025-03-31 10:07:47",{"title":157,"path":158,"stem":159,"date":160,"type":147,"children":-1},"Debian 13 稳定版安装指南及系统配置","\u002F2025\u002Fdebian-install","posts\u002F2025\u002Fdebian-install","2025-10-08 10:14:30",1782547830156]
[{"data":1,"prerenderedAt":268},["ShallowReactive",2],{"content:\u002F2025\u002Fedgeone-fndocker":3,"surround:\u002F2025\u002Fedgeone-fndocker":257},{"id":4,"title":5,"body":6,"categories":231,"date":233,"description":234,"draft":235,"extension":236,"image":237,"meta":238,"navigation":240,"path":241,"permalink":237,"published":237,"readingTime":242,"recommend":237,"references":237,"seo":247,"sitemap":248,"stem":249,"tags":250,"top":235,"type":254,"updated":255,"__hash__":256},"content\u002Fposts\u002F2025\u002Fedgeone-fndocker.md","利用EdgeOne Pages给飞牛容器一个固定域名",{"type":7,"value":8,"toc":222},"minimark",[9,17,21,31,34,37,47,69,72,82,85,89,97,102,109,120,126,130,133,139,149,164,167,171,192,196,199,202],[10,11,13],"alert",{"type":12},"error",[14,15,16],"p",{},"此教程编写于2025年11月份，部分功能可能无法使用！",[18,19,20],"h2",{"id":20},"写在前面",[14,22,23,24],{},"其原因是看到一个仓库",[25,26,30],"a",{"href":27,"rel":28},"https:\u002F\u002Fgithub.com\u002Fmyflavor\u002Fedge-ug-docker",[29],"nofollow","myflavor\u002Fedge-ug-docker",[14,32,33],{},"该仓库是利用Edge Pages反代绿联的docker代理，实现使用自己的域名直接访问docker端口",[14,35,36],{},"那么飞牛的同理，我们也可以使用飞牛的FN Connect服务，为自己的Docker容器端口绑定一个自己的域名，实现上述操作。",[10,38,39],{},[14,40,41,42],{},"飞牛API参考仓库：",[25,43,46],{"href":44,"rel":45},"https:\u002F\u002Fgithub.com\u002FFNOSP\u002Ffnnas-api",[29],"FNOSP\u002Ffnnas-api",[10,48,50,53,61],{"type":49},"info",[14,51,52],{},"由于飞牛的API使用的是websocket，所以需要一个api服务对外提供查询服务，随后使用一个前端服务对API返回的url地址进行反代。",[14,54,55,56],{},"API项目：",[25,57,60],{"href":58,"rel":59},"https:\u002F\u002Fgithub.com\u002Folinll\u002Fedge-fn-docker-api",[29],"olinll\u002Fedge-fn-docker-api",[14,62,63,64],{},"前端反代项目：",[25,65,68],{"href":66,"rel":67},"https:\u002F\u002Fgithub.com\u002Folinll\u002Fedge-fn-docker",[29],"olinll\u002Fedge-fn-docker",[18,70,71],{"id":71},"部署",[10,73,75],{"type":74},"warning",[14,76,77,78,81],{},"这里事先声明，API只需要部署一套，反代服务可以部署多套",[79,80],"br",{},"\n例：需要反代 5432、8080、9001，那么你就部署3个反代服务，分别配置不同的环境变量即可！",[14,83,84],{},"首先Fork我的两个项目，打开腾讯EdgeOne Pages页面，部署API服务",[18,86,88],{"id":87},"api服务","API服务",[14,90,91,92,96],{},"选择main分支，构建设置默认即可，配置环境变量",[93,94,95],"code",{"code":95},"GLOBAL_AUTH_KEY"," 为一个随机值，用于后续访问的鉴权密钥。",[98,99],"pic",{"caption":100,"src":101},"部署项目","https:\u002F\u002Foss.olinl.com\u002Fedgeone-fndocker\u002F20260627152625_6q90.webp",[14,103,104,105],{},"点击开始部署，然后添加一个",[106,107,108],"strong",{},"自定义域名并且配置HTTPS",[10,110,111],{"type":49},[14,112,113,114,116,117,119],{},"PS：配置eo提供的域名需要token访问且只能维持3小时，所以这里需要使用自定义的域名。",[79,115],{},"\n添加域名的方法可参考腾讯云配置，这里不做太多赘述。",[79,118],{},"\neo控制台->添加域名-> 根据选择的方式进行验证域名-> 配置pages自定义域名-> 去域名托管商配置上生成的cname记录-> 配置https -> 等待生效",[14,121,122,123,125],{},"Pages主界面显示运行中，",[106,124,88],{},"部署完成，下面开始部署反代页面",[98,127],{"caption":128,"src":129},"部署完成","https:\u002F\u002Foss.olinl.com\u002Fedgeone-fndocker\u002F20260627152704_2kwq.webp",[18,131,132],{"id":132},"反代服务",[14,134,135,136,138],{},"首先创建项目，选择你fork的edge-fn-docker仓库，生产分支main",[79,137],{},"\n然后配置环境变量（可以直接复制进去填写变量值）",[140,141,147],"pre",{"className":142,"code":144,"language":145,"meta":146},[143],"language-sql","FN_ID=           \u002F\u002F 你的FNID\nFN_USERNAME=  \u002F\u002F 你的飞牛NAS登录名\nFN_PASSWORD=  \u002F\u002F 你的飞牛NAS登录密码\nFN_PORT=          \u002F\u002F 目标服务的端口号\nFN_KEY=          \u002F\u002F API服务的GLOBAL_AUTH_KEY\nFN_API=          \u002F\u002F API服务配置的域名\n","sql","",[93,148,144],{"__ignoreMap":146},[10,150,151,154,159],{"type":74},[14,152,153],{},"这里一定要在飞牛创建一个管理员用户去使用，一定不要使用默认的管理员用户。",[14,155,156],{},[106,157,158],{},"！！！以防一些未知问题导致用户密码错误次数过多被封禁！！！",[14,160,161],{},[106,162,163],{},"！！！以防一些未知问题！！！",[14,165,166],{},"最终配置如图",[98,168],{"caption":169,"src":170},"环境变量配置","https:\u002F\u002Foss.olinl.com\u002Fedgeone-fndocker\u002F20260627152755_p05o.webp",[14,172,173,174,176,179,181,182,184,185,188,189,191],{},"点击开始部署，等待部署完成，使用上面的方式绑定自己的自定义域名。",[79,175],{},[106,177,178],{},"创建KV存储",[79,180],{},"\n1、点击pages下面的KV存储，创建一个命名空间，这里可以随便命名",[79,183],{},"\n2、找到你的反代服务(就是edge-fn-docker)，点击KV存储，绑定命名空间，变量名称填写",[93,186,187],{"code":187},"nas","，绑定上面创建的命名空间。",[79,190],{},"\n创建完成如图所示",[98,193],{"caption":194,"src":195},"配置KV存储","https:\u002F\u002Foss.olinl.com\u002Fedgeone-fndocker\u002F20260627152822_n2ew.webp",[14,197,198],{},"最后，打开你绑定的服务域名，即可访问飞牛NAS上的服务。",[18,200,201],{"id":201},"写在最后",[14,203,204,205,207,208,210,214,216,219,221],{},"如果出现访问出错，请检查上述配置是否正确，填写的环境变量是否出错！",[79,206],{},"\n如果配置无误，请检查你的FN Connect服务是否能正常打开，如无法打开，请登录飞牛，开关FN Connect开关进行重启服务。",[79,209],{},[211,212,213],"em",{},"其他问题请联系作者。",[79,215],{},[106,217,218],{},"免责声明",[79,220],{},"\n如果此仓库违反了飞牛私有云用户协议，请联系我此篇文章和相关仓库。",{"title":146,"searchDepth":223,"depth":223,"links":224},4,[225,227,228,229,230],{"id":20,"depth":226,"text":20},2,{"id":71,"depth":226,"text":71},{"id":87,"depth":226,"text":88},{"id":132,"depth":226,"text":132},{"id":201,"depth":226,"text":201},[232],"网络","2025-11-28 15:16:40","使用飞牛的Connect服务，提供的临时域名动态反代到EdgeOnePages，为容器提供一个固定域名。",false,"md",null,{"slots":239},{},true,"\u002F2025\u002Fedgeone-fndocker",{"text":243,"minutes":244,"time":245,"words":246},"5 min read",4.395,263700,879,{"title":5,"description":234},{"loc":241},"posts\u002F2025\u002Fedgeone-fndocker",[251,252,253],"EdgeOne","飞牛","容器","tech","2026-06-27 15:16:40","XKlFYzrq05yvxBwZ1t6xiP7vsSFb7BsmIx8nklDWLbA",[258,263],{"title":259,"path":260,"stem":261,"date":262,"type":254,"children":-1},"Halo博客Hao主题添加个人导航页","\u002F2025\u002Fhalo-hao-navigation","posts\u002F2025\u002Fhalo-hao-navigation","2025-11-09",{"title":264,"path":265,"stem":266,"date":267,"type":254,"children":-1},"Docker 部署 Uptime Kuma 监控服务","\u002F2025\u002Fdocker-uptime-kuma","posts\u002F2025\u002Fdocker-uptime-kuma","2026-10-10 15:16:40",1782547829070]
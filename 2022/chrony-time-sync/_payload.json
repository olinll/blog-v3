[{"data":1,"prerenderedAt":143},["ShallowReactive",2],{"content:\u002F2022\u002Fchrony-time-sync":3,"surround:\u002F2022\u002Fchrony-time-sync":132},{"id":4,"title":5,"body":6,"categories":106,"date":108,"description":109,"draft":110,"extension":111,"image":112,"meta":113,"navigation":115,"path":116,"permalink":112,"published":112,"readingTime":117,"recommend":112,"references":112,"seo":122,"sitemap":123,"stem":124,"tags":125,"top":110,"type":129,"updated":130,"__hash__":131},"content\u002Fposts\u002F2022\u002Fchrony-time-sync.md","Linux 服务器时间同步配置（Chrony）",{"type":7,"value":8,"toc":96},"minimark",[9,17,22,33,37,43,55,59,66,70,76,80,86,90],[10,11,13],"alert",{"type":12},"question",[14,15,16],"p",{},"服务器时间同步非常重要，数据库、缓存、日志、监控等服务都依赖准确的时间。随着运行时间增长，系统时钟会产生漂移，建议通过 Chrony 定期同步。",[18,19,21],"h2",{"id":20},"一设置时区","一、设置时区",[23,24,30],"pre",{"className":25,"code":27,"language":28,"meta":29},[26],"language-bash","sudo timedatectl set-timezone Asia\u002FShanghai\n","bash","",[31,32,27],"code",{"__ignoreMap":29},[18,34,36],{"id":35},"二安装-chrony","二、安装 Chrony",[23,38,41],{"className":39,"code":40,"language":28,"meta":29},[26],"# CentOS \u002F RHEL\nyum install -y chrony\n\n# Ubuntu \u002F Debian\napt install -y chrony\n",[31,42,40],{"__ignoreMap":29},[44,45,46,49],"tip",{},[14,47,48],{},"如果服务器无法直连公网，可先配置 HTTP 代理再安装：",[23,50,53],{"className":51,"code":52,"language":28,"meta":29},[26],"export http_proxy=http:\u002F\u002F192.168.1.87:3128\nexport https_proxy=http:\u002F\u002F192.168.1.87:3128\n",[31,54,52],{"__ignoreMap":29},[18,56,58],{"id":57},"三配置-ntp-服务器","三、配置 NTP 服务器",[23,60,64],{"className":61,"code":62,"filename":63,"language":28,"meta":29},[26],"# 内网 NTP 服务器（优先）\nserver 192.168.1.244 iburst\n\n# 国内公共 NTP 源（备用）\nserver ntp.aliyun.com iburst\nserver time1.cloud.tencent.com iburst\nserver ntp1.aliyun.com iburst\nserver ntp.sjtu.edu.cn iburst\nserver cn.ntp.org.cn iburst\n","\u002Fetc\u002Fchrony.conf | \u002Fetc\u002Fchrony\u002Fchrony.conf",[31,65,62],{"__ignoreMap":29},[18,67,69],{"id":68},"四启动服务","四、启动服务",[23,71,74],{"className":72,"code":73,"language":28,"meta":29},[26],"systemctl enable chronyd --now\nsystemctl status chronyd\n",[31,75,73],{"__ignoreMap":29},[18,77,79],{"id":78},"五验证时间同步","五、验证时间同步",[23,81,84],{"className":82,"code":83,"language":28,"meta":29},[26],"# 查看同步跟踪状态\nchronyc tracking\n\n# 查看时间源列表\nchronyc sources -v\n",[31,85,83],{"__ignoreMap":29},[18,87,89],{"id":88},"六启用-ntp-并查看状态","六、启用 NTP 并查看状态",[23,91,94],{"className":92,"code":93,"language":28,"meta":29},[26],"timedatectl set-ntp true\ntimedatectl\n",[31,95,93],{"__ignoreMap":29},{"title":29,"searchDepth":97,"depth":97,"links":98},4,[99,101,102,103,104,105],{"id":20,"depth":100,"text":21},2,{"id":35,"depth":100,"text":36},{"id":57,"depth":100,"text":58},{"id":68,"depth":100,"text":69},{"id":78,"depth":100,"text":79},{"id":88,"depth":100,"text":89},[107],"系统","2022-05-20 10:11:22","使用 Chrony 工具为 Linux 服务器配置时间同步，支持阿里云、腾讯云等国内 NTP 源及内网 NTP 服务器。",false,"md",null,{"slots":114},{},true,"\u002F2022\u002Fchrony-time-sync",{"text":118,"minutes":119,"time":120,"words":121},"2 min read",1.025,61500,205,{"title":5,"description":109},{"loc":116},"posts\u002F2022\u002Fchrony-time-sync",[126,127,128],"Linux","时间同步","运维","tech","2026-06-27 10:11:22","eoEEuLDsX5AhdVObiddpx2VluwWq9WPb7RkTrKO3rEg",[133,138],{"title":134,"path":135,"stem":136,"date":137,"type":129,"children":-1},"「全」CentOS 安装与服务器初始化配置完整指南","\u002F2022\u002Fcentos-all-config","posts\u002F2022\u002Fcentos-all-config","2022-04-13 08:47:07",{"title":139,"path":140,"stem":141,"date":142,"type":129,"children":-1},"Docker Compose 基础篇","\u002F2022\u002Fdocker-compose-guide","posts\u002F2022\u002Fdocker-compose-guide","2022-09-18 13:25:00",1782547830576]
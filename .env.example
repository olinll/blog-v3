# ============================================================
# images-upload.py 配置文件
# ============================================================
# 复制为 .env 并填入真实值:  cp .env.example .env
# 支持两个上传目标，可不填全——用到哪个填哪个即可。
# ============================================================

# ----------------------------------------------------------
# Cloudflare R2（目标: r2）
# ----------------------------------------------------------
# Account ID —— Cloudflare 面板 → R2 → 右上角 Account ID
R2_ACCOUNT_ID=your-account-id
# Access Key —— R2 面板 → Manage R2 API Tokens → 创建
R2_ACCESS_KEY=your-access-key
# Secret Key —— 创建 Token 时一次性显示
R2_SECRET_KEY=your-secret-key
# Bucket 名称
R2_BUCKET=your-bucket
# 公开访问域名（CDN / 自定义域名）
R2_PUBLIC_DOMAIN=https://assets.yourdomain.com
# 上传路径前缀（留空则文件直接放 slug 目录下）
R2_UPLOAD_PREFIX=images

# ----------------------------------------------------------
# 阿里云 OSS（目标: oss）
# ----------------------------------------------------------
# AccessKey ID —— RAM 控制台 → 用户 → 创建 AccessKey
OSS_ACCESS_KEY_ID=your-access-key-id
# AccessKey Secret
OSS_ACCESS_KEY_SECRET=your-access-key-secret
# Endpoint（地域节点，例如 oss-cn-shanghai.aliyuncs.com）
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
# Bucket 名称
OSS_BUCKET=your-bucket
# 公开访问域名（CDN / OSS 默认域名）
OSS_PUBLIC_DOMAIN=https://oss.yourdomain.com
# 上传路径前缀（留空则文件直接放 slug 目录下）
OSS_UPLOAD_PREFIX=

# ----------------------------------------------------------
# 通用配置
# ----------------------------------------------------------
# 输出模板: "md" = ![](url),  "pic" = ---\nsrc: url\ncaption: \n---\n::
OUTPUT_FORMAT=pic
# WebP 质量 (0-100)
WEBP_QUALITY=100
# WebP 压缩方法 (0-6, 越大越慢压缩率越高)
WEBP_METHOD=6

[{"data":1,"prerenderedAt":1015},["ShallowReactive",2],{"content:\u002F2024\u002Fharbor-install\u002F":3,"surround:\u002F2024\u002Fharbor-install\u002F":1014},{"id":4,"title":5,"body":6,"categories":989,"date":991,"description":992,"draft":993,"extension":994,"image":995,"meta":996,"navigation":998,"path":999,"permalink":995,"published":995,"readingTime":1000,"recommend":995,"references":995,"seo":1005,"sitemap":1006,"stem":1007,"tags":1008,"top":993,"type":1011,"updated":1012,"__hash__":1013},"content\u002Fposts\u002F2024\u002Fharbor-install.md","Harbor 私有镜像仓库安装指南",{"type":7,"value":8,"toc":966},"minimark",[9,13,33,37,54,101,104,113,120,124,134,143,149,153,159,162,274,315,397,420,423,429,432,438,442,448,466,469,473,482,488,494,500,508,518,521,527,531,544,550,554,557,565,604,617,621,628,635,643,649,678,681,889,892,905,908,914,921,924,930],[10,11,12],"p",{},"Harbor 是一个开源镜像仓库，通过策略和基于角色的访问控制保护镜像，是 CNCF 毕业项目。内网搭建 Harbor 可避免依赖第三方镜像仓库，对无网环境尤为友好。",[14,15,16],"alert",{},[10,17,18,19,23,24,27,28,32],{},"本文统一使用 ",[20,21,22],"code",{"code":22},"harbor.local"," 作为示例域名、",[20,25,26],{"code":26},"192.168.2.11"," 作为示例服务器 IP。实际部署请替换为你自己的值，",[29,30,31],"strong",{},"各处保持完全一致","（证书 CN \u002F Docker certs.d 目录名 \u002F hosts 映射 \u002F Nginx server_name 等）。",[34,35,36],"h2",{"id":36},"前置条件",[14,38,39,47],{},[10,40,41,42],{},"尚未安装 Docker？参见：",[43,44,46],"a",{"href":45},"\u002F2022\u002Fdocker-guide\u002F","Docker 安装与配置指南",[10,48,49,50],{},"Docker Compose 安装与使用参见：",[43,51,53],{"href":52},"\u002F2022\u002Fdocker-compose-guide\u002F","Docker Compose 安装配置",[55,56,57,64,78,84,90,96],"ul",{},[58,59,60,63],"li",{},[29,61,62],{},"Docker Engine ≥ 20.10","（Harbor 2.x 要求）",[58,65,66,69,70,73,74,77],{},[29,67,68],{},"Docker Compose","（Harbor 安装脚本会自动识别 ",[20,71,72],{"code":72},"docker compose"," 插件或老版 ",[20,75,76],{"code":76},"docker-compose"," 二进制）",[58,79,80,83],{},[29,81,82],{},"内存 ≥ 4 GB","（官方建议，低于 4 GB 部分组件会启动失败）",[58,85,86,89],{},[29,87,88],{},"磁盘 ≥ 40 GB","（Harbor 自身约 1 GB，其余留给镜像仓库存储）",[58,91,92,95],{},[29,93,94],{},"端口 80 \u002F 443","（或你自定义的端口）未被其他服务占用",[58,97,98],{},[29,99,100],{},"root 或 sudo 权限",[34,102,103],{"id":103},"下载安装包",[10,105,106,107],{},"Harbor Releases：",[43,108,112],{"href":109,"rel":110},"https:\u002F\u002Fgithub.com\u002Fgoharbor\u002Fharbor\u002Freleases",[111],"nofollow","Harbor - Github",[10,114,115,116,119],{},"建议选择 ",[20,117,118],{"code":118},"offline"," 离线包，安装时自动解压内置的 Docker 镜像，无需在线拉取。",[34,121,123],{"id":122},"生成自签名-ssl-证书","生成自签名 SSL 证书",[125,126,132],"pre",{"className":127,"code":129,"language":130,"meta":131},[128],"language-bash","sudo apt update && sudo apt install -y openssl\nvim harbor_cert.cnf\n","bash","",[20,133,129],{"__ignoreMap":131},[125,135,141],{"className":136,"code":138,"filename":139,"language":140,"meta":131},[137],"language-ini","[req]\ndistinguished_name = req_distinguished_name\nx509_extensions = v3_req\nprompt = no\n\n[req_distinguished_name]\nC = CN                     # 国家代号\nST = Beijing               # 省份\nL = Beijing                # 城市\nO = MyOrg                  # 组织\nOU = DevOps                # 部门\nCN = harbor.local          # ← 替换为你的 Harbor 域名或 IP\n\n[v3_req]\nkeyUsage = keyEncipherment, dataEncipherment, digitalSignature\nextendedKeyUsage = serverAuth\nsubjectAltName = @alt_names\n\n[alt_names]\nDNS.1 = harbor.local         # 主域名\nDNS.2 = *.local              # 可选：泛域名\nIP.1 = 192.168.2.11          # ← 裸 IP 访问场景必须加，否则 Docker 推镜像会报 \"no IP SANs\"\n","harbor_cert.cnf","ini",[20,142,138],{"__ignoreMap":131},[125,144,147],{"className":145,"code":146,"language":130,"meta":131},[128],"# 生成私钥 + 自签名证书（有效期 10 年）\nopenssl req -x509 \\\n  -newkey rsa:4096 \\\n  -sha256 \\\n  -days 3650 \\\n  -nodes \\\n  -keyout harbor.key \\\n  -out harbor.crt \\\n  -config harbor_cert.cnf \\\n  -extensions v3_req\n\n# 把证书放到后续 Harbor 和 Nginx 都方便引用的位置\nsudo mkdir -p \u002Fopt\u002Fharbor\u002Fcrt\nsudo cp harbor.crt harbor.key \u002Fopt\u002Fharbor\u002Fcrt\u002F\n\n# Docker 客户端信任证书\n# 注意：目录名必须和 docker login 时用的域名完全一致\nsudo mkdir -p \u002Fetc\u002Fdocker\u002Fcerts.d\u002Fharbor.local\u002F\nsudo cp harbor.crt \u002Fetc\u002Fdocker\u002Fcerts.d\u002Fharbor.local\u002Fca.crt\n",[20,148,146],{"__ignoreMap":131},[34,150,152],{"id":151},"配置-harboryml","配置 harbor.yml",[125,154,157],{"className":155,"code":156,"language":130,"meta":131},[128],"cp harbor.yml.tmpl harbor.yml\nvim harbor.yml\n",[20,158,156],{"__ignoreMap":131},[10,160,161],{},"关键配置项：",[163,164,165,178],"table",{},[166,167,168],"thead",{},[169,170,171,175],"tr",{},[172,173,174],"th",{},"配置项",[172,176,177],{},"说明",[179,180,181,195,205,215,228,241,254,264],"tbody",{},[169,182,183,189],{},[184,185,186],"td",{},[20,187,188],{"code":188},"hostname",[184,190,191,192,194],{},"Harbor 访问域名或 IP（本文用 ",[20,193,22],{"code":22},"）",[169,196,197,202],{},[184,198,199],{},[20,200,201],{"code":201},"http.port",[184,203,204],{},"HTTP 端口（默认 80）",[169,206,207,212],{},[184,208,209],{},[20,210,211],{"code":211},"https.port",[184,213,214],{},"HTTPS 端口（默认 443）",[169,216,217,222],{},[184,218,219],{},[20,220,221],{"code":221},"https.certificate",[184,223,224,225,194],{},"CRT 证书路径（建议 ",[20,226,227],{"code":227},"\u002Fopt\u002Fharbor\u002Fcrt\u002Fharbor.crt",[169,229,230,235],{},[184,231,232],{},[20,233,234],{"code":234},"https.private_key",[184,236,237,238,194],{},"KEY 私钥路径（建议 ",[20,239,240],{"code":240},"\u002Fopt\u002Fharbor\u002Fcrt\u002Fharbor.key",[169,242,243,248],{},[184,244,245],{},[20,246,247],{"code":247},"harbor_admin_password",[184,249,250,251,194],{},"admin 初始密码（默认 ",[20,252,253],{"code":253},"Harbor12345",[169,255,256,261],{},[184,257,258],{},[20,259,260],{"code":260},"external_url",[184,262,263],{},"外部 URL 地址",[169,265,266,271],{},[184,267,268],{},[20,269,270],{"code":270},"data_volume",[184,272,273],{},"数据持久化目录（建议配置到大容量盘）",[14,275,278,291,312],{"title":276,"type":277},"务必修改默认密码 Harbor12345","warning",[10,279,280,282,283,286,287,290],{},[20,281,253],{"code":253}," 是 Harbor 官方文档里的",[29,284,285],{},"公开默认密码","——任何扫描器都会第一时间尝试它。部署完成后",[29,288,289],{},"第一件事","就是改掉：",[55,292,293,306],{},[58,294,295,296,299,300,302,303],{},"首次部署前：直接在 ",[20,297,298],{"code":298},"harbor.yml"," 里把 ",[20,301,247],{"code":247}," 改成强密码，再 ",[20,304,305],{"code":305},".\u002Finstall.sh",[58,307,308,309],{},"已经部署完成：Web UI 登录后进 ",[29,310,311],{},"用户管理 → admin → 修改密码",[10,313,314],{},"不改就部署、尤其是公网可达的 Harbor，基本等于当场被接管。",[14,316,319,333],{"title":317,"type":318},"推荐在第一次 install.sh 之前就调整好的配置","info",[10,320,321,322,324,325,328,329,332],{},"首次 ",[20,323,305],{"code":305}," 之后改部分配置需要重新 ",[20,326,327],{"code":327},".\u002Fprepare"," + 重建容器，",[29,330,331],{},"一次到位更省事","。首次安装前至少检查以下几项：",[55,334,335,345,352,366,381,390],{},[58,336,337,341,342,344],{},[29,338,339],{},[20,340,188],{"code":188},"：改成 ",[20,343,22],{"code":22},"（或你的实际域名），要和证书 CN 一致",[58,346,347,351],{},[29,348,349],{},[20,350,247],{"code":247},"：改成强密码（见上方 caution）",[58,353,354,358,359,362,363,194],{},[29,355,356],{},[20,357,270],{"code":270},"：默认 ",[20,360,361],{"code":361},"\u002Fdata","，如果根分区小必须挪到大容量盘挂载点（如 ",[20,364,365],{"code":365},"\u002Fmnt\u002Fstorage\u002Fharbor",[58,367,368,375,376,378,379],{},[29,369,370,372,373],{},[20,371,221],{"code":221}," \u002F ",[20,374,234],{"code":234},"：指向 ",[20,377,227],{"code":227}," 和 ",[20,380,240],{"code":240},[58,382,383,389],{},[29,384,385,372,387],{},[20,386,201],{"code":201},[20,388,211],{"code":211},"：如果宿主机 80\u002F443 被系统 Nginx \u002F Apache 占用，改成 31080 \u002F 31443（或任意非占用端口），再配合下文 Nginx 反向代理做对外映射",[58,391,392,396],{},[29,393,394],{},[20,395,260],{"code":260},"：用非标端口 \u002F Nginx 反代时必配，否则登录认证会走错端口（详见下方 note）",[14,398,401,404,414,417],{"title":399,"type":400},"external_url 详解","question",[10,402,403],{},"external_url 是 Harbor 配置文件中的参数，用于定义外部客户端访问该服务的基准 URL。其技术逻辑如下：",[10,405,406,407,410,411,413],{},"优先级：启用该参数后，配置中的 hostname 将失效。",[408,409],"br",{},"\n令牌生成：Harbor 的认证服务（Token Service）会根据此参数生成 OAuth 令牌挑战（Challenge）中的 realm 地址。",[408,412],{},"\n重定向逻辑：决定 Harbor 在返回 HTTP 重定向或 API 响应时，所携带的协议、域名及端口号。",[10,415,416],{},"端口同步：在通过 Nginx 映射非标准端口（如 31001）时，该参数确保后端返回的认证地址与外部监听端口一致，防止客户端因默认访问 443 端口导致连接超时。",[10,418,419],{},"配置生效：修改此参数后，必须执行 .\u002Fprepare 脚本，以重新生成各个微服务组件内部的配置文件。",[34,421,422],{"id":422},"安装",[125,424,427],{"className":425,"code":426,"language":130,"meta":131},[128],".\u002Finstall.sh\n",[20,428,426],{"__ignoreMap":131},[10,430,431],{},"修改配置后重新加载：",[125,433,436],{"className":434,"code":435,"language":130,"meta":131},[128],".\u002Fprepare\ndocker compose down\ndocker compose up -d\n",[20,437,435],{"__ignoreMap":131},[439,440,441],"h3",{"id":441},"验证部署成功",[125,443,446],{"className":444,"code":445,"language":130,"meta":131},[128],"# 1. 查看所有 Harbor 容器状态（正常应该全部 Up 且 healthy）\ndocker compose ps\n\n# 2. 检查端口监听\nss -lntp | grep -E ':(80|443)\\b'\n\n# 3. 浏览器访问 https:\u002F\u002Fharbor.local（需先配好客户端 hosts，见下一节）\n#    默认凭据：admin \u002F Harbor12345（若未改）\n",[20,447,445],{"__ignoreMap":131},[10,449,450,451,454,455,458,459,462,463,465],{},"如果 ",[20,452,453],{"code":453},"docker compose ps"," 看到某个容器在反复 ",[20,456,457],{"code":457},"Restarting","，先 ",[20,460,461],{"code":461},"docker compose logs \u003C服务名>"," 定位具体错误——绝大多数是端口冲突或 ",[20,464,298],{"code":298}," 语法问题。",[34,467,468],{"id":468},"使用",[439,470,472],{"id":471},"配置客户端-hosts","配置客户端 hosts",[10,474,475,477,478,481],{},[20,476,22],{"code":22}," 是内网自定义域名，没有公网 DNS 解析——",[29,479,480],{},"所有需要访问 Harbor 的客户端都要手动写 hosts 文件","。",[10,483,484,487],{},[29,485,486],{},"Linux \u002F macOS","：",[125,489,492],{"className":490,"code":491,"language":130,"meta":131},[128],"echo \"192.168.2.11 harbor.local\" | sudo tee -a \u002Fetc\u002Fhosts\n",[20,493,491],{"__ignoreMap":131},[10,495,496,499],{},[29,497,498],{},"Windows","（管理员 PowerShell）：",[125,501,506],{"className":502,"code":504,"language":505,"meta":131},[503],"language-powershell","Add-Content -Path \"$env:SystemRoot\\System32\\drivers\\etc\\hosts\" -Value \"192.168.2.11 harbor.local\"\n","powershell",[20,507,504],{"__ignoreMap":131},[10,509,510,511,514,515,481],{},"或者手动编辑 ",[20,512,513],{"code":513},"C:\\Windows\\System32\\drivers\\etc\\hosts","，末尾加一行 ",[20,516,517],{"code":517},"192.168.2.11 harbor.local",[10,519,520],{},"配完后验证：",[125,522,525],{"className":523,"code":524,"language":130,"meta":131},[128],"ping harbor.local\n# 应当解析到 192.168.2.11\n",[20,526,524],{"__ignoreMap":131},[439,528,530],{"id":529},"推送-拉取镜像","推送 \u002F 拉取镜像",[14,532,534,537],{"title":533,"type":277},"如果您无法拉取",[10,535,536],{},"如果您的客户端无法拉取或上传，可以参考这篇文章配置：",[538,539],"link-card",{"description":540,"icon":541,"link":542,"title":543},"在 Linux 和 Windows 客户端上配置 Docker 信任私有镜像仓库的自签名 SSL 证书，解决拉取推送时的证书验证失败问题","https:\u002F\u002Fpicsum.photos\u002F100\u002F100","\u002F2025\u002Fdocker-private-cert","Docker 配置私服自签名证书信任",[125,545,548],{"className":546,"code":547,"language":130,"meta":131},[128],"# 登录（默认 admin \u002F 你在 harbor.yml 设定的密码）\ndocker login harbor.local\n\n# 打标签\ndocker tag myapp:latest harbor.local\u002Fmyproject\u002Fmyapp:v1.0.0\n\n# 推送\ndocker push harbor.local\u002Fmyproject\u002Fmyapp:v1.0.0\n\n# 拉取\ndocker pull harbor.local\u002Fmyproject\u002Fmyapp:v1.0.0\n",[20,549,547],{"__ignoreMap":131},[34,551,553],{"id":552},"nginx-反向代理使用非-80443-端口时","Nginx 反向代理（使用非 80\u002F443 端口时）",[10,555,556],{},"当宿主机的 80\u002F443 已被其他服务占用，可以让 Harbor 监听非标端口（比如 31080\u002F31443），再用外层 Nginx 做 TLS 终结和对外映射。",[125,558,563],{"className":559,"code":561,"language":562,"meta":131},[560],"language-conf","upstream harbor_backend {\n    server 127.0.0.1:5443;   # ← 对应 harbor.yml 里的 https.port，按实际填写\n    keepalive 32;\n}\n\nserver {\n    listen 443 ssl http2;\n    server_name harbor.local;\n\n    # 复用第 3 节生成的自签名证书\n    ssl_certificate     \u002Fopt\u002Fharbor\u002Fcrt\u002Fharbor.crt;\n    ssl_certificate_key \u002Fopt\u002Fharbor\u002Fcrt\u002Fharbor.key;\n    ssl_protocols       TLSv1.2 TLSv1.3;\n    ssl_ciphers         ECDHE-RSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-GCM-SHA384;\n\n    client_max_body_size 0;   # 允许无限大镜像上传，必加\n\n    location \u002F {\n        proxy_pass https:\u002F\u002Fharbor_backend;\n\n        # 关键：Harbor 后端也是 HTTPS（自签证书），Nginx 默认会尝试验证且必定失败，要关掉\n        proxy_ssl_verify off;\n\n        proxy_set_header Host $host;\n        proxy_set_header X-Real-IP $remote_addr;\n        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;\n        proxy_set_header X-Forwarded-Proto $scheme;\n        proxy_buffering off;\n        proxy_request_buffering off;\n        proxy_connect_timeout 90s;\n        proxy_send_timeout    90s;\n        proxy_read_timeout    90s;\n    }\n}\n\nserver {\n    listen 80;\n    server_name harbor.local;\n    return 301 https:\u002F\u002F$host$request_uri;\n}\n","conf",[20,564,561],{"__ignoreMap":131},[14,566,568,583],{"title":567,"type":400},"关于双 TLS 架构",[10,569,570,571,574,575,582],{},"上面是 ",[29,572,573],{},"Nginx HTTPS → Harbor HTTPS"," 的双 TLS 结构（Nginx 和 Harbor 可以共用同一张自签证书，也可以各用各的）。",[29,576,577,578,581],{},"即便两边用同一张证书，",[20,579,580],{"code":580},"proxy_ssl_verify off;"," 仍然要加","——Nginx 作为 TLS 客户端去连后端时，默认会走完整的 CA 链校验，自签证书没有\"可信 CA\"，所以一定失败。关掉校验后加密仍然在，只是不再做身份验证。",[10,584,585,586,589,590,592,593,596,597,599,600,603],{},"如果嫌双 TLS 麻烦，还有一种更常见的简化架构：",[29,587,588],{},"Harbor 跑 HTTP","（",[20,591,298],{"code":298}," 里注释掉整个 ",[20,594,595],{"code":595},"https:"," 块、只留 ",[20,598,201],{"code":201},"），",[29,601,602],{},"Nginx 做唯一的 TLS 终结","。宿主机本地 Docker 网络里的 HTTP 流量不出机器，风险可接受、配置更简单。",[14,605,606,609],{},[10,607,608],{},"如果你的 harbor 是非标端口，请使用下面的 nginx 配置",[125,610,615],{"className":611,"code":613,"language":614,"meta":131},[612],"language-nginx","location \u002F {\n    proxy_pass https:\u002F\u002Fharbor_backend; # 指向 Harbor 内部的 30443\n    proxy_ssl_verify off;\n\n    proxy_set_header Host $host:31001; # 显式告诉后端外部端口\n    proxy_set_header X-Real-IP $remote_addr;\n    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;\n    proxy_set_header X-Forwarded-Proto $scheme;\n    proxy_set_header X-Forwarded-Port 31001; # 必须明确告诉是 31001\n\n    # 下面两项对大镜像上传至关重要\n    proxy_buffering off;\n    proxy_request_buffering off;\n}\n","nginx",[20,616,613],{"__ignoreMap":131},[34,618,620],{"id":619},"使用-http不推荐生产环境","使用 HTTP（不推荐生产环境）",[14,622,625],{"title":623,"type":624},"注意！","error",[10,626,627],{},"不知道为什么，这个在新的docker版本无法使用，必须https",[10,629,630,631,634],{},"在 Docker 的 ",[20,632,633],{"code":633},"daemon.json"," 中添加：",[125,636,641],{"className":637,"code":639,"language":640,"meta":131},[638],"language-json","{\n  \"insecure-registries\": [\"harbor.local\"]\n}\n","json",[20,642,639],{"__ignoreMap":131},[125,644,647],{"className":645,"code":646,"language":130,"meta":131},[128],"systemctl restart docker\n",[20,648,646],{"__ignoreMap":131},[14,650,652,661,672],{"title":651,"type":277},"HTTP 模式的真实风险",[10,653,654,657,658,487],{},[20,655,656],{"code":656},"insecure-registries"," 模式下，Docker 和 Harbor 之间",[29,659,660],{},"所有流量都是明文",[55,662,663,666,669],{},[58,664,665],{},"登录凭据（HTTP Basic Auth）直接在请求头里裸奔——被嗅探就是当场被盗号",[58,667,668],{},"镜像层数据也走明文，既能被拦截拷贝、也可能被篡改（例如注入恶意二进制）",[58,670,671],{},"任何链路上的中间人（交换机、路由器、代理、公共 Wi-Fi AP）都能看到并改写",[10,673,674,677],{},[29,675,676],{},"仅适用于完全隔离的实验网络","。只要有一点外部访问，或涉及生产凭据，都必须走 HTTPS。",[34,679,680],{"id":680},"故障排查",[163,682,683,696],{},[166,684,685],{},[169,686,687,690,693],{},[172,688,689],{},"现象",[172,691,692],{},"可能原因",[172,694,695],{},"对策",[179,697,698,731,758,781,802,827,847,869],{},[169,699,700,709,715],{},[184,701,702,705,706],{},[20,703,704],{"code":704},"docker login"," 报 ",[20,707,708],{"code":708},"x509: certificate signed by unknown authority",[184,710,711,714],{},[20,712,713],{"code":713},"certs.d"," 目录名和登录时用的域名对不上",[184,716,717,718,720,721,724,725,727,728],{},"目录名必须和 ",[20,719,704],{"code":704}," 时用的域名",[29,722,723],{},"完全一致","：登录 ",[20,726,22],{"code":22}," 就放 ",[20,729,730],{"code":730},"\u002Fetc\u002Fdocker\u002Fcerts.d\u002Fharbor.local\u002Fca.crt",[169,732,733,741,744],{},[184,734,735,705,738],{},[20,736,737],{"code":737},"docker push",[20,739,740],{"code":740},"x509: cannot validate certificate for 192.168.x.x because it doesn't contain any IP SANs",[184,742,743],{},"证书没有 IP SAN",[184,745,746,747,749,750,753,754,757],{},"在 ",[20,748,139],{"code":139}," 的 ",[20,751,752],{"code":752},"[alt_names]"," 段加 ",[20,755,756],{"code":756},"IP.1 = 192.168.x.x","，重新签发",[169,759,760,768,775],{},[184,761,762,764,765],{},[20,763,737],{"code":737}," 大镜像报 ",[20,766,767],{"code":767},"413 Request Entity Too Large",[184,769,770,771,774],{},"Nginx ",[20,772,773],{"code":773},"client_max_body_size"," 限制",[184,776,777,778],{},"确认 Nginx 配置里有 ",[20,779,780],{"code":780},"client_max_body_size 0;",[169,782,783,789,794],{},[184,784,785,786],{},"登录报 ",[20,787,788],{"code":788},"unauthorized: authentication required",[184,790,791,793],{},[20,792,260],{"code":260}," 配置错，Harbor 返回的 token realm 对不上实际访问地址",[184,795,796,797,799,800],{},"核对 ",[20,798,260],{"code":260}," 协议 \u002F 域名 \u002F 端口和浏览器地址栏一致，改完跑 ",[20,801,327],{"code":327},[169,803,804,807,813],{},[184,805,806],{},"浏览器访问白屏或 502",[184,808,809,810],{},"Nginx upstream 端口不对 \u002F 没关 ",[20,811,812],{"code":812},"proxy_ssl_verify",[184,814,815,816,749,818,820,821,824,825],{},"确认 ",[20,817,298],{"code":298},[20,819,211],{"code":211}," 和 Nginx ",[20,822,823],{"code":823},"upstream"," 端口一致；加 ",[20,826,580],{"code":580},[169,828,829,836,842],{},[184,830,831,833,834],{},[20,832,453],{"code":453}," 某容器反复 ",[20,835,457],{"code":457},[184,837,838,839,841],{},"端口冲突 \u002F ",[20,840,298],{"code":298}," 语法错 \u002F 磁盘满",[184,843,844,846],{},[20,845,461],{"code":461}," 定位具体报错",[169,848,849,856,859],{},[184,850,851,852,855],{},"hosts 配好了但 ",[20,853,854],{"code":854},"ping harbor.local"," 还不通",[184,857,858],{},"写错了行 \u002F hosts 文件有 BOM \u002F Windows 权限不够",[184,860,861,864,865,868],{},[20,862,863],{"code":863},"cat \u002Fetc\u002Fhosts"," 或 Windows 下用",[29,866,867],{},"以管理员身份","编辑；确认没有奇怪字符",[169,870,871,874,877],{},[184,872,873],{},"推送镜像非常慢或中途断开",[184,875,876],{},"Nginx 缓冲 \u002F 超时不够",[184,878,815,879,882,883,372,886],{},[20,880,881],{"code":881},"proxy_buffering off; proxy_request_buffering off;","；调大 ",[20,884,885],{"code":885},"proxy_send_timeout",[20,887,888],{"code":888},"proxy_read_timeout",[34,890,891],{"id":891},"备份与升级",[10,893,894,895,897,898,900,901,904],{},"Harbor 的全部数据都在 ",[20,896,270],{"code":270}," 指定的目录下（默认 ",[20,899,361],{"code":361},"），包括 PostgreSQL 数据、镜像层存储、Redis、日志等。",[29,902,903],{},"升级前一定要备份","，出问题才有回滚余地。",[439,906,907],{"id":907},"备份",[125,909,912],{"className":910,"code":911,"language":130,"meta":131},[128],"cd \u002Fpath\u002Fto\u002Fharbor-installer\n\n# 1. 停止 Harbor\ndocker compose down\n\n# 2. 备份数据目录（data_volume 指定的路径）\nsudo tar czf \u002Fbackup\u002Fharbor-data-$(date +%F).tar.gz \u002Fdata\n\n# 3. 备份 harbor.yml（里面有一堆你调过的配置）\ncp harbor.yml \u002Fbackup\u002Fharbor.yml.$(date +%F)\n\n# 4. 重启\ndocker compose up -d\n",[20,913,911],{"__ignoreMap":131},[10,915,916,917,920],{},"建议把 ",[20,918,919],{"code":919},"\u002Fbackup"," 目录定时同步到另一台机器或云存储，单点备份不算真正的备份。",[439,922,923],{"id":923},"升级",[125,925,928],{"className":926,"code":927,"language":130,"meta":131},[128],"# 1. 先按上面\"备份\"节做完备份\n\n# 2. 下载新版本的离线安装包、解压到新目录\ntar xvf harbor-offline-installer-v2.x.x.tgz -C \u002Fopt\u002F\ncd \u002Fopt\u002Fharbor   # 新版本目录\n\n# 3. 把旧 harbor.yml 拷过来（保留你的所有配置）\ncp \u002Fbackup\u002Fharbor.yml.\u003C日期> .\u002Fharbor.yml\n\n# 4. 停止旧版本\ncd \u002Fpath\u002Fto\u002Fold-harbor && docker compose down\n\n# 5. 在新目录安装（会自动检测 data_volume 里已有数据并升级）\ncd \u002Fopt\u002Fharbor\n.\u002Finstall.sh\n",[20,929,927],{"__ignoreMap":131},[14,931,933,936,960],{"title":932,"type":400},"升级失败的回滚思路",[10,934,935],{},"如果新版本起不来或者数据有问题：",[937,938,939,945,954],"ol",{},[58,940,941,944],{},[20,942,943],{"code":943},"docker compose down"," 停掉新版本",[58,946,947,948,950,951],{},"恢复 ",[20,949,270],{"code":270}," 目录：",[20,952,953],{"code":953},"sudo tar xzf \u002Fbackup\u002Fharbor-data-\u003C日期>.tar.gz -C \u002F",[58,955,956,957],{},"回到旧版本的安装目录 ",[20,958,959],{"code":959},"docker compose up -d",[10,961,962,963,481],{},"所以",[29,964,965],{},"备份的 tar 包必须保留到新版本稳定运行一段时间之后再删",{"title":131,"searchDepth":967,"depth":967,"links":968},4,[969,971,972,973,974,978,982,983,984,985],{"id":36,"depth":970,"text":36},2,{"id":103,"depth":970,"text":103},{"id":122,"depth":970,"text":123},{"id":151,"depth":970,"text":152},{"id":422,"depth":970,"text":422,"children":975},[976],{"id":441,"depth":977,"text":441},3,{"id":468,"depth":970,"text":468,"children":979},[980,981],{"id":471,"depth":977,"text":472},{"id":529,"depth":977,"text":530},{"id":552,"depth":970,"text":553},{"id":619,"depth":970,"text":620},{"id":680,"depth":970,"text":680},{"id":891,"depth":970,"text":891,"children":986},[987,988],{"id":907,"depth":977,"text":907},{"id":923,"depth":977,"text":923},[990],"服务","2024-07-19 14:11:19","使用 Docker Compose 部署 Harbor 私有镜像仓库，包含自签名 SSL 证书生成、YAML 配置、Nginx 反向代理等完整流程。",false,"md",null,{"slots":997},{},true,"\u002F2024\u002Fharbor-install",{"text":1001,"minutes":1002,"time":1003,"words":1004},"13 min read",12.5,750000,2500,{"title":5,"description":992},{"loc":999},"posts\u002F2024\u002Fharbor-install",[1009,1010],"docker","harbor","tech","2026-06-27 14:11:19","5_CZ-C65wp9bLnDfwLJNqSJJnFAUBn-qgEqQSrpPJzQ",[995,995],1782547831369]
[{"data":1,"prerenderedAt":258},["ShallowReactive",2],{"content:\u002F2024\u002Fsquid-proxy":3,"surround:\u002F2024\u002Fsquid-proxy":247},{"id":4,"title":5,"body":6,"categories":222,"date":224,"description":225,"draft":226,"extension":227,"image":228,"meta":229,"navigation":231,"path":232,"permalink":228,"published":228,"readingTime":233,"recommend":228,"references":228,"seo":238,"sitemap":239,"stem":240,"tags":241,"top":226,"type":244,"updated":245,"__hash__":246},"content\u002Fposts\u002F2024\u002Fsquid-proxy.md","使用 Squid 为内网服务器搭建 HTTP 代理",{"type":7,"value":8,"toc":214},"minimark",[9,24,29,40,44,50,57,64,70,77,80,86,89,93,125,130,136,140,143,148,155,161,167,173,179,185,191,197,202,205,211],[10,11,14,18],"alert",{"type":12,"title":13},"question","何意味？",[15,16,17],"p",{},"在实际运维中，经常遇到部分服务器没有公网访问权限的情况。此时可以找一台同时接入局域网和互联网的机器，安装 Squid 作为代理服务器，让内网机器借道访问外网。",[15,19,20],{},[21,22,23],"strong",{},"本篇教程只适用于在内网使用，如果您部署在外网，请自行配置防火墙等策略！！",[25,26,28],"h3",{"id":27},"安装在有网络的服务器上","安装（在有网络的服务器上）",[30,31,37],"pre",{"className":32,"code":34,"language":35,"meta":36},[33],"language-bash","# 安装 Squid\n\n## Centos\nyum install -y squid\n\n## Ubuntu\\Debian\napt install -y squid\n\n\n# 启动并设置开机自启\nsystemctl start squid\nsystemctl enable squid\n","bash","",[38,39,34],"code",{"__ignoreMap":36},[25,41,43],{"id":42},"配置-squid","配置 Squid",[30,45,48],{"className":46,"code":47,"language":35,"meta":36},[33],"# 编辑配置文件\nvim \u002Fetc\u002Fsquid\u002Fsquid.conf\n",[38,49,47],{"__ignoreMap":36},[15,51,52,53,56],{},"找到所有 ",[38,54,55],{"code":55},"http_access deny"," 行并注释掉，然后添加：",[30,58,62],{"className":59,"code":60,"filename":61,"language":35,"meta":36},[33],"# 允许所有来源访问\nhttp_access allow all\n","\u002Fetc\u002Fsquid\u002Fsquid.conf",[38,63,60],{"__ignoreMap":36},[30,65,68],{"className":66,"code":67,"language":35,"meta":36},[33],"# 重启使配置生效\nsystemctl restart squid\n",[38,69,67],{"__ignoreMap":36},[15,71,72,73,76],{},"Squid 默认监听 ",[21,74,75],{},"3128"," 端口。",[25,78,79],{"id":79},"在无网络的服务器上使用代理",[30,81,84],{"className":82,"code":83,"language":35,"meta":36},[33],"# 配置 HTTP\u002FHTTPS 代理（仅当前终端会话有效）\nexport http_proxy=http:\u002F\u002F192.168.0.217:3128\nexport https_proxy=http:\u002F\u002F192.168.0.217:3128\n\n# 验证配置\necho $http_proxy\necho $https_proxy\n\n# 测试是否生效\ncurl -I https:\u002F\u002Fwww.baidu.com\n",[38,85,83],{"__ignoreMap":36},[15,87,88],{},"复制命令区(您可以直接对下方输入框进行修改，随后复制)：",[90,91],"copy",{"code":92},"export https_proxy=http:\u002F\u002F192.168.0.217:3128 http_proxy=http:\u002F\u002F192.168.0.217:3128 all_proxy=http:\u002F\u002F192.168.0.217:3128",[10,94,96,110],{"type":95},"warning",[15,97,98,101,102,109],{},[38,99,100],{"code":100},"export"," 设置的代理仅对当前 Shell 会话有效，",[21,103,104,105,108],{},"不能使用 ",[38,106,107],{"code":107},"sudo"," 命令","（sudo 不会继承普通用户的环境变量）。",[15,111,112,113,116,117,120,121,124],{},"如需 ",[38,114,115],{"code":115},"yum"," 通过代理安装软件，请直接在 root 用户下设置，或在 ",[38,118,119],{"code":119},"\u002Fetc\u002Fyum.conf"," 中配置 ",[38,122,123],{"code":123},"proxy","。",[126,127,129],"h4",{"id":128},"在-yumconf-中永久配置代理","在 yum.conf 中永久配置代理",[30,131,134],{"className":132,"code":133,"language":35,"meta":36},[33],"vim \u002Fetc\u002Fyum.conf\n\n# 添加以下行\nproxy=http:\u002F\u002F192.168.0.217:3128\n",[38,135,133],{"__ignoreMap":36},[25,137,139],{"id":138},"ssh信息打印","SSH信息打印",[15,141,142],{},"我们可以在SSH登录的欢迎信息上把配置信息打印出来",[10,144,145],{"type":12},[15,146,147],{},"在 Ubuntu 22.04 中，这种登录时显示的提示词被称为 MOTD (Message of the Day)。",[149,150,151],"ol",{},[152,153,154],"li",{},"创建自定义提示脚本\n在 Ubuntu 中，登录提示是按数字顺序执行 \u002Fetc\u002Fupdate-motd.d\u002F 下的脚本生成的。我们创建一个高优先级的脚本（例如 99-proxy-tip）：",[30,156,159],{"className":157,"code":158,"language":35,"meta":36},[33],"sudo nano \u002Fetc\u002Fupdate-motd.d\u002F99-proxy-tip\n",[38,160,158],{"__ignoreMap":36},[149,162,164],{"start":163},2,[152,165,166],{},"写入提示内容\n将以下代码粘贴进去。你可以使用 ANSI 转义码来给关键信息加粗或上色（例如用红色提醒“切勿使用 sudo”）：",[30,168,171],{"className":169,"code":170,"language":35,"meta":36},[33],"#!\u002Fbin\u002Fsh\n\necho \"\"\necho \"************************ 重要提示 ************************\"\necho \"此服务器无互联网，如需连接互联网请运行如下命令：\"\necho \"export http_proxy=http:\u002F\u002F192.168.1.63:3128\"\necho \"export https_proxy=http:\u002F\u002F192.168.1.63:3128\"\necho \"\"\n# 使用红色加粗显示警告\necho \"\\033[1;31m警告：请直接在当前用户下运行，切勿使用 sudo！\\033[0m\"\necho \"********************************************************\"\necho \"\"\n",[38,172,170],{"__ignoreMap":36},[149,174,176],{"start":175},3,[152,177,178],{},"赋予执行权限\n只有具备可执行权限的脚本才会被 update-motd 调用：",[30,180,183],{"className":181,"code":182,"language":35,"meta":36},[33],"sudo chmod +x \u002Fetc\u002Fupdate-motd.d\u002F99-proxy-tip\n",[38,184,182],{"__ignoreMap":36},[149,186,188],{"start":187},4,[152,189,190],{},"即时测试查看效果\n不需要重新登录，直接运行以下命令即可预览",[30,192,195],{"className":193,"code":194,"language":35,"meta":36},[33],"sudo run-parts \u002Fetc\u002Fupdate-motd.d\u002F\n",[38,196,194],{"__ignoreMap":36},[15,198,199],{},[21,200,201],{},"进阶：如果你想让用户“一键启用”",[15,203,204],{},"为了避免用户手动复制粘贴出错，你可以在 \u002Fetc\u002Fprofile.d\u002F 下放一个别名（Alias）：",[30,206,209],{"className":207,"code":208,"language":35,"meta":36},[33],"sudo nano \u002Fetc\u002Fprofile.d\u002Fproxy.sh\n\n# 写入\nalias setproxy=\"export http_proxy=http:\u002F\u002F192.168.1.63:3128 && export https_proxy=http:\u002F\u002F192.168.1.63:3128\"\nalias unsetproxy=\"unset http_proxy && unset https_proxy\"\n",[38,210,208],{"__ignoreMap":36},[15,212,213],{},"这样你在登录提示里就可以写：“输入 setproxy 即可开启上网模式”。",{"title":36,"searchDepth":187,"depth":187,"links":215},[216,217,218,221],{"id":27,"depth":175,"text":28},{"id":42,"depth":175,"text":43},{"id":79,"depth":175,"text":79,"children":219},[220],{"id":128,"depth":187,"text":129},{"id":138,"depth":175,"text":139},[223],"服务","2024-07-20 09:48:41","在有网络的边缘服务器上安装 Squid 代理，让无公网访问的内网机器通过代理完成软件安装与网络请求。",false,"md",null,{"slots":230},{},true,"\u002F2024\u002Fsquid-proxy",{"text":234,"minutes":235,"time":236,"words":237},"4 min read",3.55,213000,710,{"title":5,"description":225},{"loc":232},"posts\u002F2024\u002Fsquid-proxy",[242,243],"Squid","代理","tech","2026-06-27 09:48:41","W2rZ3N_wRiY6wNLDg_IeGgb3NQO71f8cnhL6Yd8Tk8k",[248,253],{"title":249,"path":250,"stem":251,"date":252,"type":244,"children":-1},"Harbor 私有镜像仓库安装指南","\u002F2024\u002Fharbor-install","posts\u002F2024\u002Fharbor-install","2024-07-19 14:11:19",{"title":254,"path":255,"stem":256,"date":257,"type":244,"children":-1},"LVM 硬盘工具使用教程","\u002F2024\u002Flvm-guide","posts\u002F2024\u002Flvm-guide","2024-09-17 14:31:01",1782547830296]
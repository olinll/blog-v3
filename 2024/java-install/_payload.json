[{"data":1,"prerenderedAt":155},["ShallowReactive",2],{"content:\u002F2024\u002Fjava-install":3,"surround:\u002F2024\u002Fjava-install":144},{"id":4,"title":5,"body":6,"categories":119,"date":121,"description":122,"draft":123,"extension":124,"image":125,"meta":126,"navigation":128,"path":129,"permalink":125,"published":125,"readingTime":130,"recommend":125,"references":125,"seo":135,"sitemap":136,"stem":137,"tags":138,"top":123,"type":141,"updated":142,"__hash__":143},"content\u002Fposts\u002F2024\u002Fjava-install.md","Linux 手动安装 JDK 1.8 并配置环境变量",{"type":7,"value":8,"toc":113},"minimark",[9,56,59,64,75,79,85,91],[10,11,12,16,19,22,25,32,35,37,40,43,45,51,53],"chat",{},[13,14,15],"p",{},"{:2602-12-31 23:59:59}",[13,17,18],{},"{.}",[13,20,21],{},"老大，都2602年了，这样的教程还值得放在我的博客文章里吗？",[13,23,24],{},"{喵墩}",[13,26,27,28,31],{},"JDK 8 在2026年还在大量生产环境跑着（Spring Boot 2.x、Hadoop、老项目一堆）",[29,30],"br",{},"\n这篇教程对新人踩坑还是有参考价值的。",[13,33,34],{},"{:渋夜旅 撤回了一条消息}",[13,36,24],{},[13,38,39],{},"但你应该在文章头部加一段提示：\"新项目建议直接装 JDK 21+，本文仅适用于维护旧项目\"。",[13,41,42],{},"{:娜娜奇 不知道在做什么 反正就是有了个踪迹在这}",[13,44,18],{},[13,46,47,48,50],{},"那我就把这个聊天记录加上去，但我不想改哇。",[29,49],{},"\n算了，等用得到的时候再改吧",[13,52,18],{},[13,54,55],{},"其实就是下载不同版本的jdk包，然后替换就行了。",[13,57,58],{},"一般情况下推荐直接下载 tar.gz 包配置环境变量，而不是通过包管理器安装，便于管理多个 JDK 版本。",[60,61,63],"h2",{"id":62},"一下载解压","一、下载解压",[65,66,72],"pre",{"className":67,"code":69,"language":70,"meta":71},[68],"language-bash","# 下载 JDK 1.8\n# 华为云官方地址\nwget https:\u002F\u002Frepo.huaweicloud.com\u002Fjava\u002Fjdk\u002F8u201-b09\u002Fjdk-8u201-linux-x64.tar.gz\n\n# 解压并移动到 \u002Fopt\ntar -zxvf jdk-8u201-linux-x64.tar.gz\nmv jdk1.8.0_201 \u002Fopt\u002Fjdk1.8\u002F\n","bash","",[73,74,69],"code",{"__ignoreMap":71},[60,76,78],{"id":77},"二配置环境变量","二、配置环境变量",[65,80,83],{"className":81,"code":82,"language":70,"meta":71},[68],"# 编辑系统环境变量\nvim \u002Fetc\u002Fprofile\n\n# 在文件末尾追加以下内容\n# Java 1.8\nexport JAVA_HOME=\u002Fopt\u002Fjdk1.8\nexport PATH=$JAVA_HOME\u002Fbin:$PATH\nexport CLASSPATH=.:$JAVA_HOME\u002Flib\u002Fdt.jar:$JAVA_HOME\u002Flib\u002Ftools.jar\n\n# 使配置立即生效\nsource \u002Fetc\u002Fprofile\n\n# 验证安装，显示版本号即成功\njava -version\n",[73,84,82],{"__ignoreMap":71},[65,86,89],{"className":87,"code":88,"language":70,"meta":71},[68],"# 预期输出\njava version \"1.8.0_201\"\nJava(TM) SE Runtime Environment (build 1.8.0_201-b09)\nJava HotSpot(TM) 64-Bit Server VM (build 25.201-b09, mixed mode)\n",[73,90,88],{"__ignoreMap":71},[92,93,95],"alert",{"type":94},"info",[13,96,97,98,101,102,101,105,108,109,112],{},"如果服务器上需要同时管理多个 JDK 版本，可以将不同版本分别解压到 ",[73,99,100],{"code":100},"\u002Fopt\u002Fjdk1.8\u002F","、",[73,103,104],{"code":104},"\u002Fopt\u002Fjdk11\u002F",[73,106,107],{"code":107},"\u002Fopt\u002Fjdk17\u002F"," 等目录，通过修改 ",[73,110,111],{"code":111},"JAVA_HOME"," 快速切换。",{"title":71,"searchDepth":114,"depth":114,"links":115},4,[116,118],{"id":62,"depth":117,"text":63},2,{"id":77,"depth":117,"text":78},[120],"服务","2024-06-20","使通过下载 tar.gz 包手动安装 JDK 1.8，配置 JAVA_HOME 等环境变量，适用于 CentOS、Debian、Ubuntu 等主流发行版。",false,"md",null,{"slots":127},{},true,"\u002F2024\u002Fjava-install",{"text":131,"minutes":132,"time":133,"words":134},"2 min read",1.915,114900,383,{"title":5,"description":122},{"loc":129},"posts\u002F2024\u002Fjava-install",[139,140],"docker","harbor","tech","2026-06-27 14:11:19","PC4CNNdPhhlzYhIGZzOvB9tHGRBa9jDDgC7jjv17q4U",[145,150],{"title":146,"path":147,"stem":148,"date":149,"type":141,"children":-1},"Linux 管理 JAR 服务的 Shell 脚本","\u002F2022\u002Fjar-service-sh","posts\u002F2022\u002Fjar-service-sh","2022-10-20 10:11:22",{"title":151,"path":152,"stem":153,"date":154,"type":141,"children":-1},"Harbor 私有镜像仓库安装指南","\u002F2024\u002Fharbor-install","posts\u002F2024\u002Fharbor-install","2024-07-19 14:11:19",1782547830422]
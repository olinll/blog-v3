[{"data":1,"prerenderedAt":156},["ShallowReactive",2],{"content:\u002F2026\u002Fbasic-auth-auto-login-bypass":3,"surround:\u002F2026\u002Fbasic-auth-auto-login-bypass":145},{"id":4,"title":5,"body":6,"categories":119,"date":121,"description":122,"draft":123,"extension":124,"image":125,"meta":126,"navigation":128,"path":129,"permalink":130,"published":130,"readingTime":131,"recommend":130,"references":130,"seo":136,"sitemap":137,"stem":138,"tags":139,"top":123,"type":142,"updated":143,"__hash__":144},"content\u002Fposts\u002F2026\u002Fbasic-auth-auto-login-bypass.md","跳过登录弹框：实现 Basic Auth 自动授权",{"type":7,"value":8,"toc":112},"minimark",[9,13,17,24,29,33,36,42,45,48,52,55,58,61,71,74,82,85,89,92,101],[10,11,12],"h2",{"id":12},"前言",[14,15,16],"p",{},"问题原因呢，是我在整理书签和密码填充工具的时候发现的一个问题，对于这样的弹框，因为是直接弹出在浏览器的，密码填充工具无法进行填充账号密码等信息。",[14,18,19,20],{},"下面的鉴权方式就是：",[21,22,23],"code",{"code":23},"Basic Auth",[25,26],"pic",{"caption":27,"src":28},"Basic Auth鉴权方式实例","https:\u002F\u002Foss.olinl.com\u002Fbasic-auth-auto-login-bypass\u002F20260627091109_dx09.webp",[10,30,32],{"id":31},"什么是basic-auth","什么是Basic Auth？",[14,34,35],{},"Basic Auth，也称为 HTTP 基本认证（HTTP Basic Authentication），是一种用于 HTTP 协议的简单认证机制。在 Basic Auth 中，客户端在发送请求时，将用户名和密码以 Base64 编码的形式包含在请求头的 Authorization 字段中发送给服务器，服务器收到请求后，会解码 Authorization 字段并验证用户名和密码。",[14,37,38],{},[39,40,41],"strong",{},"如何判断你这个web页面是不是Basic Auth？",[14,43,44],{},"先看弹窗样式，弹窗样式紧贴浏览器的搜索栏(上图)",[14,46,47],{},"打开F12 查看请求的接口响应头信息，看到Www-Authenticate的值包含Basic，并且状态码为401",[25,49],{"caption":50,"src":51},"验证是否为Basic Auth","https:\u002F\u002Foss.olinl.com\u002Fbasic-auth-auto-login-bypass\u002F20260627091054_88fo.webp",[10,53,54],{"id":54},"解决问题",[14,56,57],{},"那么堡垒机是怎么解决此类问题的？",[14,59,60],{},"selenium操作这里Basic Auth网站的实现方式是：直接把用户名和密码拼接到URL中进行访问。",[62,63,69],"pre",{"className":64,"code":66,"language":67,"meta":68},[65],"language-py","from selenium import webdriver\ndriver = webdriver.Chrome()\ndriver.get('http:\u002F\u002Fadmin:password@10.1.13.80:9100')\n","py","",[21,70,66],{"__ignoreMap":68},[14,72,73],{},"于是，我就使用他的方式进行拼接了一下，就访问成功了。",[75,76,79],"alert",{":card":77,"type":78},"true","warning",[14,80,81],{},"URL 中的凭据会出现在浏览器历史记录、服务器日志和 Referer 头中，仅在可信内网环境中使用此方式。",[14,83,84],{},"格式如下：",[86,87],"copy",{":prompt":77,"code":88},"http:\u002F\u002F\u003C用户名>:\u003C密码>@\u003Cip地址或域名>:\u003C端口号，如果是80可以不填>",[86,90],{":prompt":77,"code":91},"https:\u002F\u002F\u003C用户名>:\u003C密码>@\u003Cip地址或域名>:\u003C端口号，如果是443可以不填>",[14,93,94,95,98],{},"例如：",[96,97],"br",{},[21,99,100],{"code":100},"http:\u002F\u002Fadmin:password@10.1.13.80:9100",[75,102,104,109],{":card":77,"type":78,"title":103},"使用FRP会报一个错误",[14,105,106],{},[21,107,108],{"code":108},"Get server info from frps failed!",[14,110,111],{},"这个错误是正常的用户名密码的参数传递和请求的不符，把url后面的路径删掉在访问就可以了。",{"title":68,"searchDepth":113,"depth":113,"links":114},4,[115,117,118],{"id":12,"depth":116,"text":12},2,{"id":31,"depth":116,"text":32},{"id":54,"depth":116,"text":54},[120],"网络","2026-01-03","详解如何通过 URL 传参、Nginx 反向代理注入 Header 以及浏览器插件等方式，实现对 Basic Auth 认证站点的免密自动登录。",false,"md","https:\u002F\u002Foss.olinl.com\u002Fcover\u002Fbasic-auth-auto-login-bypass.webp",{"slots":127},{},true,"\u002F2026\u002Fbasic-auth-auto-login-bypass",null,{"text":132,"minutes":133,"time":134,"words":135},"3 min read",2.055,123300,411,{"title":5,"description":122},{"loc":129},"posts\u002F2026\u002Fbasic-auth-auto-login-bypass",[23,140,141],"Nginx","安全","tech","2026-06-27 09:08:39","E2qjSB0mZKC24dO5ph2XlUjZNUEavP2brtUKfPFWBpE",[146,151],{"title":147,"path":148,"stem":149,"date":150,"type":142,"children":-1},"利用EdgeOne Pages给飞牛容器一个固定域名","\u002F2025\u002Fedgeone-fndocker","posts\u002F2025\u002Fedgeone-fndocker","2025-11-28 15:16:40",{"title":152,"path":153,"stem":154,"date":155,"type":142,"children":-1},"FRP 内网穿透服务部署指南","\u002F2026\u002Ffrp-deploy","posts\u002F2026\u002Ffrp-deploy","2026-02-07",1782825156158]
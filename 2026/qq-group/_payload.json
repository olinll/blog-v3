[{"data":1,"prerenderedAt":126},["ShallowReactive",2],{"content:\u002F2026\u002Fqq-group":3,"surround:\u002F2026\u002Fqq-group":120},{"id":4,"title":5,"body":6,"categories":96,"date":98,"description":99,"draft":100,"extension":101,"image":102,"meta":103,"navigation":105,"path":106,"permalink":107,"published":107,"readingTime":108,"recommend":107,"references":107,"seo":113,"sitemap":114,"stem":115,"tags":116,"top":105,"type":118,"updated":98,"__hash__":119},"content\u002Fposts\u002F2026\u002Fqq-group.md","欢迎加入 Olinl 的 QQ 交流群 🎉",{"type":7,"value":8,"toc":89},"minimark",[9,13,16,49,52,55,60,71,76,80,83,86],[10,11,12],"p",{},"你好呀，我是 顾拾柒。",[10,14,15],{},"这个博客断断续续写了有一阵子了，分享的大多是技术折腾、学习笔记和一些零碎的思考。虽然写东西本身是件挺私人的事，但每次看到评论区或者后台有朋友留言交流，还是觉得——有人一起聊，真好。",[17,18,19,22,25,28,31,34,36,39,41,44,46],"chat",{},[10,20,21],{},"{:2026-06-25 20:30:00}",[10,23,24],{},"{.}",[10,26,27],{},"这群能干啥？",[10,29,30],{},"{顾拾柒}",[10,32,33],{},"聊技术、聊生活、看群主翻车",[10,35,24],{},[10,37,38],{},"翻车好看吗？",[10,40,30],{},[10,42,43],{},"每天都有新花样 🫠",[10,45,24],{},[10,47,48],{},"那我来了",[10,50,51],{},"所以，我建了一个 QQ 群。",[10,53,54],{},"就是上面聊到的这样——不一定多正经，但一定有人说话。不管你是来学点东西、看群主翻车，还是单纯找个地方摸鱼，都欢迎。",[56,57,59],"h2",{"id":58},"怎么加群","📌 怎么加群？",[10,61,62,63,70],{},"扫描下方二维码，或者点击链接加入群聊【",[64,65,69],"a",{"href":66,"rel":67},"https:\u002F\u002Fqm.qq.com\u002Fq\u002FKCNRzy51uy",[68],"nofollow","Olinl Blog 技术交流群","】",[72,73],"pic",{"caption":74,"src":75},"扫一扫二维码，加入群聊","https:\u002F\u002Foss.olinl.com\u002F_blog\u002Fqrcode.webp",[56,77,79],{"id":78},"最后","🔗 最后",[10,81,82],{},"如果这篇文章对你有帮助，或者你只是路过觉得这个博客还有点意思，不妨加个群进来坐坐。",[10,84,85],{},"我可能不是回复最快的人，但每条消息我都会看。",[10,87,88],{},"期待在群里见到你。",{"title":90,"searchDepth":91,"depth":91,"links":92},"",4,[93,95],{"id":58,"depth":94,"text":59},2,{"id":78,"depth":94,"text":79},[97],"杂项","2026-06-24 23:58:21","一个人走得快，一群人走得远。",false,"md","https:\u002F\u002Foss.olinl.com\u002Fcover\u002Fqq-group-1.webp",{"slots":104},{},true,"\u002F2026\u002Fqq-group",null,{"text":109,"minutes":110,"time":111,"words":112},"2 min read",1.44,86400,288,{"title":5,"description":99},{"loc":106},"posts\u002F2026\u002Fqq-group",[117],"交流","story","a0bY3wzF7gRV4HQl6de9eXWZhPXqtsrqkOeCItBTCH0",[121,107],{"title":122,"path":123,"stem":124,"date":125,"type":118,"children":-1},"迁移多次网站后，我回归了博客的本质","\u002F2026\u002Fless-blog","posts\u002F2026\u002Fless-blog","2026-06-23 20:13:26",1782547829070]
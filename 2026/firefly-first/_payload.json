[{"data":1,"prerenderedAt":971},["ShallowReactive",2],{"content:\u002F2026\u002Ffirefly-first":3,"surround:\u002F2026\u002Ffirefly-first":961},{"id":4,"title":5,"body":6,"categories":935,"date":937,"description":938,"draft":939,"extension":940,"image":941,"meta":942,"navigation":944,"path":945,"permalink":946,"published":946,"readingTime":947,"recommend":946,"references":946,"seo":952,"sitemap":953,"stem":954,"tags":955,"top":939,"type":958,"updated":959,"__hash__":960},"content\u002Fposts\u002F2026\u002Ffirefly-first.md","「迁」Firefly 博客部署教程",{"type":7,"value":8,"toc":899},"minimark",[9,14,19,27,57,63,70,74,115,120,127,135,142,147,155,165,169,174,177,183,187,191,200,204,208,216,220,224,227,234,238,241,245,248,254,257,261,264,268,272,275,278,284,288,291,301,307,311,316,322,335,338,341,347,354,357,363,372,375,382,386,389,392,402,406,409,412,415,418,421,427,431,434,437,452,464,468,471,474,485,493,501,505,564,583,601,604,620,623,626,629,637,642,645,648,651,654,658,675,680,684,698,711,716,719,723,726,729,734,737,741,757,760,764,775,778,782,799,806,813,819,823,826,834,837,850,854,860,864,875,896],[10,11],"video-embed",{"id":12,"type":13},"BV17Njb6nEH8","bilibili",[15,16,18],"h2",{"id":17},"一前置准备","一、前置准备",[20,21,22,23,26],"p",{},"你是否想拥有一个属于自己的博客，却不知道从何下手？",[24,25],"br",{},"\n今天我们将从购买域名开始，一步步教你部署一个静态博客。",[28,29,32,39,48,54],"alert",{"title":30,"type":31},"什么是静态站点","info",[20,33,34,38],{},[35,36,37],"strong",{},"传统模式",": 我们需要在服务器上安装相关组件，每次访问都要动态生成页面，消耗服务器CPU。这也是为什么需要买云服务器。",[20,40,41,44,45,47],{},[35,42,43],{},"现代静态模式","：我们只需要把构建生成的静态文件上传到 Vercel、CloudFlare 或 EdgeOne 的全球边缘节点上",[24,46],{},"\n当用户访问时，CDN（内容分发网络）直接把这些现成的文件返给浏览器，不需要后端服务器执行任何代码。",[20,49,50,53],{},[35,51,52],{},"结论","：“所以，所谓'无服务器'，并不是真的没有物理机器，而是我们不需要去管理、维护、付费买一台专用的云主机。",[20,55,56],{},"我们只需要为文件存储和网络流量付费。对于个人博客，这三家平台提供的免费额度已经完全够用了！”",[20,58,59,60,62],{},"本篇教程适用于Firefly、Fuwari、Mizuki 等类型的博客。",[24,61],{},"\n涵盖了Cloudflare workers、Vercel、腾讯云Edgeone 3类平台的部署教程。",[28,64,67],{"title":65,"type":66},"注意","warning",[20,68,69],{},"部分情况可能需要特殊的网络环境，如无法正常访问请尝试更换网络环境。",[71,72,73],"h3",{"id":73},"安装必备环境",[75,76,77,88,91,99,107],"ul",{},[78,79,80,87],"li",{},[81,82,86],"a",{"href":83,"rel":84},"https:\u002F\u002Fnodejs.org\u002F",[85],"nofollow","Node.js","：关键运行环境",[78,89,90],{},"pnpm：包管理工具，使用npm进行安装。",[78,92,93,98],{},[81,94,97],{"href":95,"rel":96},"https:\u002F\u002Fgit-scm.cn\u002F",[85],"Git","：版本控制，用于拉取、提交代码。",[78,100,101,106],{},[81,102,105],{"href":103,"rel":104},"https:\u002F\u002Fdesktop.github.com",[85],"GitHub Desktop"," github官方客户端",[78,108,109,114],{},[81,110,113],{"href":111,"rel":112},"https:\u002F\u002Fcode.visualstudio.com",[85],"VS Code","：编辑器，用于修改配置、写文章。",[116,117,119],"h4",{"id":118},"安装nodejs","安装Node.js",[20,121,122,123,126],{},"这里推荐安装",[35,124,125],{},"LTS","稳定版，版本需要 ≥ 22",[20,128,129,130],{},"可以点击链接进行下载：",[81,131,134],{"href":132,"rel":133},"https:\u002F\u002Fnodejs.org\u002Fdist\u002Fv24.17.0\u002Fnode-v24.17.0-x64.msi",[85],"Node.js v24.17.0 LTS",[20,136,137,138],{},"或者打开下载页面手动下载：",[81,139,140],{"href":140,"rel":141},"https:\u002F\u002Fnodejs.org\u002Fzh-cn\u002Fdownload",[85],[143,144],"pic",{"caption":145,"src":146},"下载Node.JS","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623210318_48c1.webp",[20,148,149,150,154],{},"下载完成后进行安装，默认选项直接下一步即可。随后我们打开",[151,152,153],"code",{"code":153},"终端","窗口，执行以下命令验证版本号是否正确",[156,157,163],"pre",{"className":158,"code":160,"language":161,"meta":162},[159],"language-bash","node -v\nnpm -v\n","bash","",[151,164,160],{"__ignoreMap":162},[143,166],{"caption":167,"src":168},"验证版本号","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623210335_fz71.webp",[20,170,171,173],{},[35,172,65],{},"：安装后重启终端，无效则重启电脑。",[116,175,176],{"id":176},"安装pnpm",[156,178,181],{"className":179,"code":180,"language":161,"meta":162},[159],"npm install -g pnpm\n\n# 随后执行如下命令进行验证\npnpm -v\n",[151,182,180],{"__ignoreMap":162},[143,184],{"caption":185,"src":186},"安装并验证pnpm","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623210350_kmvg.webp",[116,188,190],{"id":189},"安装-git","安装 Git",[20,192,193,194,199],{},"访问 ",[81,195,198],{"href":196,"rel":197},"https:\u002F\u002Fgit-scm.cn\u002Finstall\u002Fwindows",[85],"下载页面","，下载最新版并默认安装",[143,201],{"caption":202,"src":203},"下载Git","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623210403_vjvm.webp",[116,205,207],{"id":206},"安装github-desktop","安装Github Desktop",[20,209,210,211,215],{},"点击访问：",[81,212,198],{"href":213,"rel":214},"https:\u002F\u002Fdesktop.github.com\u002Fdownload\u002F",[85]," 点击进行下载",[143,217],{"caption":218,"src":219},"绑定账号","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623210418_rghz.webp",[116,221,223],{"id":222},"安装vs-code","安装VS Code",[20,225,226],{},"如果您有更好的编辑器，可以安装其他的。",[20,228,210,229,233],{},[81,230,198],{"href":231,"rel":232},"https:\u002F\u002Fcode.visualstudio.com\u002FDownload",[85]," 选择您的系统进行下载",[143,235],{"caption":236,"src":237},"下载VSCode","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623210431_8tnx.webp",[20,239,240],{},"随后进行安装即可。",[15,242,244],{"id":243},"二fork-firefly-官方仓库","二、Fork Firefly 官方仓库",[20,246,247],{},"打开Firefly官方仓库：",[249,250],"link-card",{"description":251,"link":252,"title":253},"流萤，清新美观的 Astro 静态博客主题模板，Material Design 3 风格设计","https:\u002F\u002Fgithub.com\u002FCuteLeaf\u002FFirefly","CuteLeaf\u002FFirefly",[20,255,256],{},"点击右上角的「Fork」按钮。",[143,258],{"caption":259,"src":260},"Fork仓库","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623210551_rs7m.webp",[20,262,263],{},"填写信息后，点击「Create Fork」后，会自动跳转到你自己的仓库。",[143,265],{"caption":266,"src":267},"填写信息后Fork","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623210605_0bby.webp",[15,269,271],{"id":270},"三克隆仓库并修改配置","三、克隆仓库并修改配置",[20,273,274],{},"现在我们已经拥有了Firefly 仓库，需要将它的代码克隆到本地，进行修改配置，编写文档等。",[71,276,277],{"id":277},"克隆并本地运行",[20,279,280,281,283],{},"我们打开GitHub Desktop 搜索Firefly 点击下方的Clone 按钮 拉取代码",[24,282],{},"\n然后选择一个本地的目录存储。",[143,285],{"caption":286,"src":287},"选择项目 拉取代码","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623210619_j4oi.webp",[20,289,290],{},"然后右键项目目录，通过code打开。",[20,292,293,294,296,297,300],{},"点击顶部的",[151,295,153],{"code":153}," ",[151,298,299],{"code":299},"新建终端","，然后在新打开的终端输入下面的命令进行安装依赖",[156,302,305],{"className":303,"code":304,"language":161,"meta":162},[159],"pnpm install\n",[151,306,304],{"__ignoreMap":162},[143,308],{"caption":309,"src":310},"打开终端","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623210631_4st7.webp",[20,312,313],{},[35,314,315],{},"启动本地预览",[156,317,320],{"className":318,"code":319,"language":161,"meta":162},[159],"pnpm dev\n",[151,321,319],{"__ignoreMap":162},[20,323,324,325],{},"等待10-30秒，终端显示访问地址 ",[326,327,331],"tip",{":copy":328,"icon":329,"tip":330},"true","tabler:copy","复制下方内容",[81,332,333],{"href":333,"rel":334},"http:\u002F\u002Flocalhost:4321",[85],[20,336,337],{},"打开浏览器输入该地址，看到Firefly默认首页，即本地搭建成功。",[71,339,340],{"id":340},"修改关键配置",[20,342,343,344],{},"点击左侧目录树，配置文件夹：",[151,345,346],{"code":346},"src\u002Fconfig\u002F",[20,348,349,350],{},"这里可以根据官网文档自定义你的站点：",[81,351,352],{"href":352,"rel":353},"https:\u002F\u002Fdocs-firefly.cuteleaf.cn\u002Fzh\u002Fguide\u002Fsite.html",[85],[71,355,356],{"id":356},"如何编写文章",[20,358,359,360],{},"点击左侧目录树，文章文件夹：",[151,361,362],{"code":362},"src\u002Fcontent\u002Fposts\u002F",[20,364,365,366,371],{},"文章使用",[81,367,370],{"href":368,"rel":369},"https:\u002F\u002Fmarkdown.com.cn\u002Fbasic-syntax\u002Findex.html",[85],"Markdown"," 格式",[20,373,374],{},"最上面是文章的属性信息,定义文章的标题，发布日期等等。",[20,376,377,378],{},"具体可以参考官网文档：",[81,379,380],{"href":380,"rel":381},"https:\u002F\u002Fdocs-firefly.cuteleaf.cn\u002Fzh\u002Fguide\u002Fwriting.html",[85],[71,383,385],{"id":384},"上传github","上传Github",[20,387,388],{},"我们在修改完配置，编写完文章后，要将相关的代码上传到GitHub，这里使用Git工具上传，有2种方式，",[20,390,391],{},"1、Github Desktop",[20,393,394,395,398,399],{},"我们在GitHub Desktop 勾选需要提交的文件，在下面输入提交消息，然后点击",[151,396,397],{"code":397},"commit"," 按钮 然后点击上方的",[151,400,401],{"code":401},"Psuh origin",[143,403],{"caption":404,"src":405},"客户端提交代码","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623210747_mcgc.webp",[20,407,408],{},"2、使用VS Code",[20,410,411],{},"VS Code 左侧有一个源代码管理，在这里可以上传代码，写消息，查看历史变更等。",[20,413,414],{},"只需要右键需要提交的文件，点击添加到暂存更改，填入消息之后点击提交按钮，随后点击推送，即可成功推送。",[20,416,417],{},"当然，我们也可以直接填入消息之后点击提交，然后点击推送，将所有更改的文件进行提交。",[20,419,420],{},"3、或者，我们也可以使用git命令",[156,422,425],{"className":423,"code":424,"language":161,"meta":162},[159],"# 将文件添加到暂存区\ngit add . \n\n# 将暂存区的文件提交到本地仓库\ngit commit -m \"更新内容\" \n\n# 将本地提交推送到远程仓库\ngit push\n",[151,426,424],{"__ignoreMap":162},[15,428,430],{"id":429},"四部署站点","四、部署站点",[20,432,433],{},"上面我们已经把自己的代码同步到了GitHub，我们需要让部署程序去关联 GitHub，并自动构建部署，发布到互联网。",[20,435,436],{},"这里提供了3种方式，Cloudflare Workers、Vercel、腾讯EdgeOne",[438,439,440,443,446,449],"blockquote",{},[20,441,442],{},"这三种有什么特点",[20,444,445],{},"Cloudflare Workers 通吃，绑定域名无需备案，可以实现优选加速访问等等。",[20,447,448],{},"Vercel 优点是部署快速，而且提供的域名可以实现国内访问，不像Cloudflare存在SNI封锁的问题",[20,450,451],{},"腾讯Edgeone 优点是国内的大牌CDN，国内访问特别迅速，缺点是域名必须备案。",[28,453,455,458,461],{"title":454,"type":326},"提醒",[20,456,457],{},"如果你的站点已经过了ICP或者ICP+公安网备，那么这里推荐使用EdgeOne对你的站点进行加速。",[20,459,460],{},"因为根据SNI封禁策略，ICP备案的站点访问速度会比正常的站点要快。",[20,462,463],{},"你无需担心监管问题，因为公安网信办会定期检查你的网站有无违规，是否正常访问。",[71,465,467],{"id":466},"部署到cloudfare-workers","部署到Cloudfare Workers",[116,469,470],{"id":470},"检查配置文件",[20,472,473],{},"由于我们是要部署到 Cloudflare，需要确保项目里的 Worker 配置文件正确。",[20,475,476,477,480,481,484],{},"在项目根目录找到 ",[151,478,479],{"code":479},"wrangler.jsonc","，确认内容大致如下（",[35,482,483],{},"如果项目已自带，无需新建","）：",[156,486,491],{"className":487,"code":489,"language":490,"meta":162},[488],"language-jsonc","{\n\t\"name\": \"firefly\",\n\t\"compatibility_date\": \"2025-01-01\",\n\t\"compatibility_flags\": [\"nodejs_compat\"],\n\t\"assets\": {\n\t\t\"directory\": \".\u002Fdist\"\n\t}\n}\n","jsonc",[151,492,489],{"__ignoreMap":162},[28,494,495],{"title":65,"type":66},[20,496,497,500],{},[151,498,499],{"code":499},"name"," 修改为你的Worker项目名称",[116,502,504],{"id":503},"新建-cloudflare-worker-应用","新建 Cloudflare Worker 应用",[506,507,508,519,529,538,552,558],"ol",{},[78,509,510,513,514,518],{},[35,511,512],{},"登录 Cloudflare 控制台"," 打开浏览器访问官方控制台：",[81,515,516],{"href":516,"rel":517},"https:\u002F\u002Fdash.cloudflare.com\u002F",[85],"，输入账号密码完成登录。",[78,520,521,524,525,528],{},[35,522,523],{},"进入 Workers & Pages 页面"," 登录后，在左侧菜单栏找到并点击 ",[35,526,527],{},"Workers 和 Pages","（英文对应：Workers & Pages），进入应用管理页面。",[78,530,531,534,535,537],{},[35,532,533],{},"创建应用程序"," 在页面右上角，点击 ",[35,536,533],{},"（英文对应：Create application），进入应用创建流程。",[78,539,540,543,544,547,548,551],{},[35,541,542],{},"关联 GitHub 代码仓库"," 在创建页面中，选择 ",[35,545,546],{},"连接到 Git（Connect Git）","，然后选中 ",[35,549,550],{},"GitHub","，按照页面提示完成授权，允许 Cloudflare 访问你的 GitHub 账号。",[78,553,554,557],{},[35,555,556],{},"选择目标仓库"," 授权完成后，系统会列出你的 GitHub 所有仓库，从中选中需要部署到 Cloudflare Worker 的代码仓库（如 Firefly 仓库）。",[78,559,560,563],{},[35,561,562],{},"配置构建设置"," ：",[75,565,566,575],{},[78,567,568,571,572],{},[35,569,570],{},"Build command",": ",[151,573,574],{"code":574},"pnpm build",[78,576,577,571,580],{},[35,578,579],{},"Deploy command",[151,581,582],{"code":582},"npx wrangler deploy",[506,584,585,595],{},[78,586,587,590,591,594],{},[35,588,589],{},"发起首次部署"," 配置完成后，点击页面底部的 ",[35,592,593],{},"部署（Deploy）","，启动首次自动部署流程。",[78,596,597,600],{},[35,598,599],{},"等待自动构建完成"," Cloudflare 会自动执行三个操作：拉取 GitHub 仓库代码 → 执行构建命令 → 将项目部署至 Workers 服务器，耐心等待即可。。",[116,602,603],{"id":603},"验证自动部署是否成功",[506,605,606,617],{},[78,607,608,609,612,613,616],{},"当构建状态显示“成功”后，点击 Worker 项目顶部的 ",[35,610,611],{},"临时域名","（格式为：",[151,614,615],{"code":615},"xxx.workers.dev","）。",[78,618,619],{},"打开浏览器访问该临时域名，若页面展示效果与本地预览的博客首页完全一致，说明 Cloudflare Worker 与 GitHub 自动部署配置成功。",[116,621,622],{"id":622},"绑定域名",[20,624,625],{},"因为Worker提供的域名，在国内SNI封禁的情况下可能会无法访问。所以，我们需要绑定一个自己的域名。",[20,627,628],{},"2种方式",[506,630,631,634],{},[78,632,633],{},"你的域名托管在Cloudflare，那么你可以直接在Worker 的 domains 绑定你的域名。",[78,635,636],{},"如果你的域名不在Cloudflare，那么你需要把你的托管到Cloudflare去使用。",[20,638,639],{},[35,640,641],{},"将域名托管到Cloudflare",[20,643,644],{},"点击域名-> 连接域名，添加你的域名，然后根据提示修改dns服务器地址。",[20,646,647],{},"随后点击到worker 里面，绑定你的域名。",[116,649,650],{"id":650},"验证是否成功",[20,652,653],{},"在浏览器打开你的域名后成功访问即可。",[116,655,657],{"id":656},"cloudflare-worker-域名优选","Cloudflare Worker 域名优选",[438,659,660,667],{},[20,661,662,666],{},[663,664,665],"span",{},"!NOTE"," 提示",[20,668,669,670,674],{},"本节只复述操作过程，如果你想了解更多，可以前往：",[81,671,673],{"href":672},"\u002F2026\u002Fcf-fastip\u002F","使用CloudFlare优选任何网站！"," 了解更多。",[20,676,677],{},[35,678,679],{},"首先我们创建一条这样的记录",[143,681],{"caption":682,"src":683},"创建优选域名","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623210935_i77u.webp",[75,685,686,689,692,695],{},[78,687,688],{},"名称：可自定义，",[78,690,691],{},"类型：CNAME",[78,693,694],{},"内容：*.cf.090227.xyz 其中 * 支持任意字母，例如 youxuan.cf.090227.xyz",[78,696,697],{},"代理状态：仅DNS 关闭小黄云",[438,699,700,705,708],{},[20,701,702,704],{},[663,703,665],{}," CF小黄云",[20,706,707],{},"cf小黄云指的就是这里的代理状态。",[20,709,710],{},"因为Cloudflare的节点都在国外，所以这个小黄云在你不会用的情况下，不要开启，否则会成为国内的减速器！",[20,712,713],{},[35,714,715],{},"创建Worker 路由",[20,717,718],{},"到Worker 里面，点击域，点击添加路由",[143,720],{"caption":721,"src":722},"创建Worker路由","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623210948_tg1k.webp",[20,724,725],{},"然后选择你的域名，随后填写最终访问的域名+\u002F*",[20,727,728],{},"例如：访问的域名 blog.example.com  那么我们就填写 blog.example.com\u002F*",[20,730,731],{},[35,732,733],{},"创建DNS解析记录",[20,735,736],{},"到域名的DNS记录里面，添加一条记录",[143,738],{"caption":739,"src":740},"添加Worker的DNS解析记录","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623211001_5jzc.webp",[75,742,743,746,749,755],{},[78,744,745],{},"名称：Worker的路由前缀，如果你填写是：blog.example.com\u002F* 那么就在这里填写 blog",[78,747,748],{},"类型:CNAME",[78,750,751,752,754],{},"内容：上面创建的优选域名，本篇是cdn.olinl.top 如果你修改了，那么就按照你修改后的来",[24,753],{},"\n请注意！这里的olinl.top 是我的域名，不要填错了，请填写cdn.xxx 你自己的域名！",[78,756,697],{},[20,758,759],{},"最后，我们来检查一下：",[143,761],{"caption":762,"src":763},"最终配置","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623211017_851u.webp",[506,765,766,769,772],{},[78,767,768],{},"优选域名配置，内容必须是*.cf.090227.xyz 格式，且关闭小黄云",[78,770,771],{},"Worker 路由，必须是 \u003C前缀>.\u003C你的域名>\u002F* 这个格式",[78,773,774],{},"Worker DNS记录：名称必须和 Worker路由保持一致，内容必须是1. 配置的优选域名，且关闭小黄云",[20,776,777],{},"然后就可以打开配置的域名去访问了。",[71,779,781],{"id":780},"部署到vercel","部署到Vercel",[20,783,784,785,790,791,794,795,798],{},"打开",[81,786,789],{"href":787,"rel":788},"https:\u002F\u002Fvercel.com\u002F",[85],"Vercel","并登录，进入控制台，点击",[151,792,793],{"code":793},"Add New..."," 绑定你的Gtihub账号，选择需要部署的仓库，点击 ",[151,796,797],{"code":797},"import","。",[20,800,801,802,805],{},"随后再次点击",[151,803,804],{"code":804},"Deploy"," 开始部署即可。",[20,807,808,809,812],{},"部署完成后，我们可以在 ",[151,810,811],{"code":811},"Domains"," 查看Vercel给我们生成的域名，这个域名可以作为长期域名使用，国内也可以访问。",[20,814,815,816,818],{},"当然我们也可以在",[151,817,811],{"code":811},"选项卡绑定自己的域名。",[71,820,822],{"id":821},"部署到-腾讯云edgeone","部署到 腾讯云EdgeOne",[116,824,825],{"id":825},"开始部署",[20,827,784,828,833],{},[81,829,832],{"href":830,"rel":831},"https:\u002F\u002Fconsole.cloud.tencent.com\u002Fedgeone\u002Fmakers",[85],"腾讯云 边缘安全加速EO - Makers","，点击创建项目，导入Git仓库，选择需要部署的仓库。",[20,835,836],{},"修改名称为小写字母，然后直接点击开始部署即可。",[20,838,839,840,843,844,846],{},"部署成功后，我们可以点击",[151,841,842],{"code":842},"域名管理"," 然后点击临时域名进行访问。",[24,845],{},[847,848,849],"del",{},"有些小聪明想要借助这个临时域名进行跳过备案访问，不好意思，这个临时域名是带时间戳的，超时或不带时间戳token访问会弹401",[116,851,853],{"id":852},"绑定域名并签发ssl证书","绑定域名并签发SSL证书",[20,855,856,857,859],{},"在",[151,858,842],{"code":842},"添加我们已备案的域名，然后根据CNAME去我们的域名托管商配置CNAME记录，如下图！",[143,861],{"caption":862,"src":863},"配置域名解析","https:\u002F\u002Foss.olinl.com\u002Ffirefly-first\u002F20260623211030_gbgd.webp",[75,865,866,869,872],{},[78,867,868],{},"主机记录填写你域名的前缀",[78,870,871],{},"类型选择CNAME",[78,873,874],{},"记录值填写腾讯云给你的记录",[20,876,877,878,881,882,885,886,888,889,892,893,895],{},"配置成功之后，我们点击HTTP配置下面的",[151,879,880],{"code":880},"配置","按钮，点击",[151,883,884],{"code":884},"边缘HTTPS证书","下面的",[151,887,880],{"code":880},"按钮，然后选择",[151,890,891],{"code":891},"申请免费证书","。然后点击保存即可。",[24,894],{},"\n在我们配置完CNAME之后，他会自动申请ssl证书，并且到期之前腾讯云会续签，你无需担心SSL证书到期问题。",[20,897,898],{},"等待配置状态正常后，访问站点。",{"title":162,"searchDepth":900,"depth":900,"links":901},4,[902,913,914,920],{"id":17,"depth":903,"text":18,"children":904},2,[905],{"id":73,"depth":906,"text":73,"children":907},3,[908,909,910,911,912],{"id":118,"depth":900,"text":119},{"id":176,"depth":900,"text":176},{"id":189,"depth":900,"text":190},{"id":206,"depth":900,"text":207},{"id":222,"depth":900,"text":223},{"id":243,"depth":903,"text":244},{"id":270,"depth":903,"text":271,"children":915},[916,917,918,919],{"id":277,"depth":906,"text":277},{"id":340,"depth":906,"text":340},{"id":356,"depth":906,"text":356},{"id":384,"depth":906,"text":385},{"id":429,"depth":903,"text":430,"children":921},[922,930,931],{"id":466,"depth":906,"text":467,"children":923},[924,925,926,927,928,929],{"id":470,"depth":900,"text":470},{"id":503,"depth":900,"text":504},{"id":603,"depth":900,"text":603},{"id":622,"depth":900,"text":622},{"id":650,"depth":900,"text":650},{"id":656,"depth":900,"text":657},{"id":780,"depth":906,"text":781},{"id":821,"depth":906,"text":822,"children":932},[933,934],{"id":825,"depth":900,"text":825},{"id":852,"depth":900,"text":853},[936],"教程","2026-06-12 15:46:00","手把手带你搭建一个静态的博客网站。",false,"md","https:\u002F\u002Foss.olinl.com\u002Fcover\u002Ffirefly-first.webp",{"slots":943},{},true,"\u002F2026\u002Ffirefly-first",null,{"text":948,"minutes":949,"time":950,"words":951},"15 min read",14.45,867000,2890,{"title":5,"description":938},{"loc":945},"posts\u002F2026\u002Ffirefly-first",[956,957],"搭建","Cloudflare","tech","2026-06-18 18:45:13","h7OgONneWURsvnOB7ZCHGhXvLyG42CDzrkRq99NGwYs",[962,967],{"title":963,"path":964,"stem":965,"date":966,"type":958,"children":-1},"Alpine Linux 极简安装流程与生产环境轻量化配置","\u002F2026\u002Falpine-install","posts\u002F2026\u002Falpine-install","2026-03-01",{"title":673,"path":968,"stem":969,"date":9